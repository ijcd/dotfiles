#!/usr/bin/env python3
"""workspace - terminal-agnostic workspace launcher.

Subcommands:
  up <name>         spawn the project's tabs/panes
  ls                list configured projects
  edit              open config in $EDITOR
  capture <name>    snapshot current terminal state -> draft project entry

Config:    ~/.config/workspace/projects.json
Schema:    https://… (see plans/future-tools.md in dotfiles)

Driver compatibility:
  kitty + leaf cmd        ✓  (single-cmd tab)
  kitty + tmux            ✓  (kitty tab with tmux-managed panes)
  tmux + tmux             ✓  (pure tmux session, tmuxinator-style)
  other combinations      ✗  rejected at config load
"""

import argparse
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path

CONFIG_PATH = (
    Path(os.environ.get("XDG_CONFIG_HOME") or "~/.config").expanduser()
    / "workspace"
    / "projects.json"
)

KITTEN = "/Applications/kitty.app/Contents/MacOS/kitten"

# (parent_driver, child_driver) — child is leaf if no panes/tabs below
VALID_PAIRS = {
    ("kitty", "kitty"),
    ("kitty", "tmux"),
    ("kitty", None),
    ("wezterm", "wezterm"),
    ("wezterm", "tmux"),
    ("wezterm", None),
    ("tmux", "tmux"),
    ("tmux", None),
}


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def expand(p):
    """Expand ~ and env vars; return absolute path string."""
    if not p:
        return os.path.expanduser("~")
    return os.path.expanduser(os.path.expandvars(p))


def kitty_socket():
    """Return /tmp/kitty-<pid> path or None."""
    val = os.environ.get("KITTY_LISTEN_ON", "")
    return val.replace("unix:", "") if val.startswith("unix:") else None


def slug(s):
    """Make a string safe for use as a tmux session name."""
    return "".join(c if c.isalnum() else "-" for c in s.lower()).strip("-") or "session"


def fail(msg):
    print(f"workspace: {msg}", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Drivers
# ---------------------------------------------------------------------------

class KittyDriver:
    name = "kitty"

    def __init__(self, socket=None):
        self.socket = socket or kitty_socket()
        if not self.socket:
            fail("kitty driver requires running inside kitty (KITTY_LISTEN_ON unset)")

    def _run(self, *args, capture=False):
        cmd = [KITTEN, "@", "--to", f"unix:{self.socket}", *args]
        if capture:
            return subprocess.run(cmd, capture_output=True, text=True, check=True).stdout
        subprocess.run(cmd, check=True)

    def spawn_tab(self, title, cwd, cmd=None, hold=False):
        """Create a new kitty tab. If cmd is None, just opens a shell.
        If hold is True, keeps shell open after cmd exits.
        """
        args = ["launch", "--type=tab", f"--tab-title={title}", f"--cwd={cwd}"]
        if cmd:
            if hold:
                args += ["--", "/bin/zsh", "-i", "-c", f"{cmd}; exec /bin/zsh -i"]
            else:
                args += ["--", *shlex.split(cmd)]
        self._run(*args)

    def list(self):
        return json.loads(self._run("ls", capture=True))


class TmuxDriver:
    name = "tmux"

    def _run(self, *args, capture=False):
        cmd = ["tmux", *args]
        if capture:
            return subprocess.run(cmd, capture_output=True, text=True, check=True).stdout
        subprocess.run(cmd, check=True)

    def session_exists(self, name):
        result = subprocess.run(
            ["tmux", "has-session", "-t", name],
            capture_output=True,
        )
        return result.returncode == 0

    def new_session(self, name, cwd, first_cmd=None, window_name=None):
        """Create a new detached tmux session; first window runs first_cmd or shell."""
        args = ["new-session", "-d", "-s", name, "-c", cwd]
        if window_name:
            args += ["-n", window_name]
        if first_cmd:
            args.append(first_cmd)
        self._run(*args)

    def new_window(self, session, cwd, cmd=None, window_name=None):
        args = ["new-window", "-t", session, "-c", cwd]
        if window_name:
            args += ["-n", window_name]
        if cmd:
            args.append(cmd)
        self._run(*args)

    def split_window(self, target, cwd, cmd=None, percent=None, vertical=True):
        """Split the most-recent pane of `target` (session:window)."""
        args = ["split-window", "-t", target, "-c", cwd]
        args.append("-v" if vertical else "-h")
        if percent is not None:
            args += ["-p", str(int(percent))]
        if cmd:
            args.append(cmd)
        self._run(*args)

    def select_layout(self, target, layout):
        if layout:
            self._run("select-layout", "-t", target, layout)


# ---------------------------------------------------------------------------
# Engine
# ---------------------------------------------------------------------------

def load_config():
    if not CONFIG_PATH.exists():
        fail(f"config not found at {CONFIG_PATH} — run 'workspace edit' to create it")
    try:
        return json.loads(CONFIG_PATH.read_text())
    except json.JSONDecodeError as e:
        fail(f"config has invalid JSON: {e}")


def validate(name, project):
    parent = project.get("driver")
    if parent not in (None, "kitty", "wezterm", "tmux"):
        fail(f"project {name!r}: unknown driver {parent!r}")
    for i, tab in enumerate(project.get("tabs", [])):
        if "panes" in tab:
            child = tab.get("driver", parent)
            if (parent, child) not in VALID_PAIRS:
                fail(
                    f"project {name!r} tab {i} ({tab.get('title','?')!r}): "
                    f"invalid driver combo (project={parent}, tab={child}). "
                    f"See plans/future-tools.md for valid combinations."
                )


def up_kitty_project(project_name, project):
    """Project driver = kitty: each tab is a kitty tab."""
    project_cwd = expand(project.get("cwd"))
    kitty = KittyDriver()

    for tab in project["tabs"]:
        title = f"{project_name}:{tab.get('title', 'tab')}"
        cwd = expand(tab.get("cwd")) if tab.get("cwd") else project_cwd
        cmd = tab.get("cmd")
        panes = tab.get("panes")

        if panes:
            tab_driver = tab.get("driver", "kitty")
            if tab_driver == "tmux":
                _spawn_kitty_tab_with_tmux_panes(kitty, project_name, tab, title, cwd)
            elif tab_driver == "kitty":
                fail("workspace: kitty splits as inner driver not yet implemented; use tmux for now")
            else:
                fail(f"workspace: tab driver {tab_driver!r} unsupported under kitty")
        else:
            kitty.spawn_tab(title, cwd, cmd=cmd, hold=bool(cmd))


def _spawn_kitty_tab_with_tmux_panes(kitty, project_name, tab, title, cwd):
    """Kitty tab hosting a tmux session with one window of N panes."""
    tmux = TmuxDriver()
    session_name = tab.get("session") or slug(f"{project_name}-{tab.get('title','tab')}")
    panes = tab["panes"]
    layout = tab.get("layout")
    first_cmd = panes[0].get("cmd") or ""

    if not tmux.session_exists(session_name):
        tmux.new_session(session_name, cwd, first_cmd=first_cmd or None, window_name=tab.get("title"))
        for pane in panes[1:]:
            tmux.split_window(session_name, expand(pane.get("cwd")) if pane.get("cwd") else cwd,
                              cmd=pane.get("cmd"))
        if layout:
            tmux.select_layout(session_name, layout)

    # Spawn kitty tab that attaches to the tmux session
    attach_cmd = f"tmux attach -t {shlex.quote(session_name)}"
    kitty.spawn_tab(title, cwd, cmd=attach_cmd)


def up_tmux_project(project_name, project):
    """Project driver = tmux: tabs are tmux windows in one session."""
    project_cwd = expand(project.get("cwd"))
    tmux = TmuxDriver()
    session_name = project.get("session") or slug(project_name)

    if tmux.session_exists(session_name):
        print(f"workspace: tmux session {session_name!r} already exists")
    else:
        first_tab = project["tabs"][0] if project["tabs"] else {}
        first_cmd = first_tab.get("cmd") or (first_tab.get("panes", [{}])[0].get("cmd") if first_tab.get("panes") else None)
        tmux.new_session(session_name, project_cwd, first_cmd=first_cmd,
                         window_name=first_tab.get("title", "main"))

        # Add remaining panes to first window if multi-pane
        if first_tab.get("panes") and len(first_tab["panes"]) > 1:
            for pane in first_tab["panes"][1:]:
                tmux.split_window(f"{session_name}:0", project_cwd, cmd=pane.get("cmd"))
            if first_tab.get("layout"):
                tmux.select_layout(f"{session_name}:0", first_tab["layout"])

        # Add additional windows
        for tab in project["tabs"][1:]:
            cwd = expand(tab.get("cwd")) if tab.get("cwd") else project_cwd
            cmd = tab.get("cmd")
            panes = tab.get("panes")
            window_name = tab.get("title", "tab")
            if panes:
                tmux.new_window(session_name, cwd, cmd=panes[0].get("cmd"), window_name=window_name)
                for pane in panes[1:]:
                    tmux.split_window(f"{session_name}:{window_name}", cwd, cmd=pane.get("cmd"))
                if tab.get("layout"):
                    tmux.select_layout(f"{session_name}:{window_name}", tab["layout"])
            else:
                tmux.new_window(session_name, cwd, cmd=cmd, window_name=window_name)

    # If we're in kitty, spawn a kitty tab that attaches
    if kitty_socket():
        kitty = KittyDriver()
        kitty.spawn_tab(f"{project_name}", project_cwd, cmd=f"tmux attach -t {shlex.quote(session_name)}")
    else:
        print(f"workspace: tmux session {session_name!r} ready. Attach with: tmux attach -t {session_name}")


# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

def cmd_up(args):
    cfg = load_config()
    projects = cfg.get("projects", {})
    if args.name not in projects:
        avail = ", ".join(sorted(projects)) or "(none)"
        fail(f"unknown project {args.name!r}. Available: {avail}")

    project = projects[args.name]
    validate(args.name, project)

    driver = project.get("driver", "kitty")
    if driver == "kitty":
        up_kitty_project(args.name, project)
    elif driver == "tmux":
        up_tmux_project(args.name, project)
    else:
        fail(f"driver {driver!r} not yet implemented (try kitty or tmux)")

    print(f"workspace: {args.name} up")


def cmd_ls(args):
    cfg = load_config()
    projects = cfg.get("projects", {})
    if not projects:
        print("(no projects configured — run 'workspace edit')")
        return
    print(f"{'NAME':30} {'DRIVER':10} {'TABS':6} CWD")
    for name in sorted(projects):
        p = projects[name]
        print(f"{name:30} {p.get('driver','kitty'):10} {len(p.get('tabs',[])):6} {p.get('cwd','-')}")


def cmd_edit(args):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        CONFIG_PATH.write_text(json.dumps({
            "projects": {
                "example": {
                    "driver": "kitty",
                    "cwd": "~/work/example",
                    "tabs": [
                        {"title": "claude", "cmd": "claude --dangerously-skip-permissions --continue"},
                        {"title": "shell"}
                    ]
                }
            }
        }, indent=2) + "\n")
    editor = os.environ.get("EDITOR") or os.environ.get("VISUAL") or "vi"
    os.execvp(editor, [editor, str(CONFIG_PATH)])


def normalize_cmdline(cmdline):
    """Translate a captured cmdline list to a stable shell command string.
    Returns None for plain shells (= 'just open a shell here').
    """
    if not cmdline:
        return None
    bin_name = os.path.basename(cmdline[0])
    if bin_name in ("zsh", "bash", "fish", "sh", "-zsh", "-bash"):
        return None
    # overmind's tmux backend → 'overmind start'
    if bin_name == "tmux" and any(a.startswith("overmind-") for a in cmdline):
        return "overmind start"
    return shlex.join(cmdline)


def cmd_capture(args):
    if not kitty_socket():
        fail("capture currently requires running inside kitty")
    kitty = KittyDriver()
    windows = kitty.list()
    focused = next((w for w in windows if w.get("is_focused")), windows[0] if windows else None)
    if not focused:
        fail("no kitty OS windows to capture")

    tabs = focused.get("tabs", [])
    if not tabs:
        fail("focused kitty OS window has no tabs")

    # Pick most-common cwd as project cwd
    cwds = []
    for tab in tabs:
        for w in tab.get("windows", []):
            if w.get("cwd"):
                cwds.append(w["cwd"])
    common_cwd = max(set(cwds), key=cwds.count) if cwds else "~"

    project = {"driver": "kitty", "cwd": common_cwd, "tabs": []}

    for tab in tabs:
        title = tab.get("title", "tab")
        # Strip our status indicators
        for prefix in ("⏳ ", "… ", "cc:"):
            while title.startswith(prefix):
                title = title[len(prefix):]
        first_win = (tab.get("windows") or [{}])[0]
        fg_list = first_win.get("foreground_processes", [])
        cmdline = fg_list[0].get("cmdline", []) if fg_list else []
        cmd = normalize_cmdline(cmdline)
        entry = {"title": title}
        if cmd:
            entry["cmd"] = cmd
        project["tabs"].append(entry)

    # Print as JSON snippet ready to paste into projects.json
    print(json.dumps({args.name: project}, indent=2))


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="workspace",
        description="Terminal-agnostic workspace launcher.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__.split("Subcommands:", 1)[0],
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("up", help="launch a project")
    p.add_argument("name")
    p.set_defaults(func=cmd_up)

    p = sub.add_parser("ls", help="list configured projects")
    p.set_defaults(func=cmd_ls)

    p = sub.add_parser("edit", help="open config in $EDITOR")
    p.set_defaults(func=cmd_edit)

    p = sub.add_parser("capture", help="snapshot current state into draft entry")
    p.add_argument("name", help="name to use for the captured project")
    p.set_defaults(func=cmd_capture)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
