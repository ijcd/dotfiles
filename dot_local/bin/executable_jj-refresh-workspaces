#!/bin/sh
# jj-refresh-workspaces - refresh stale jj workspaces after a history rewrite you
# want to "flow through" to every workspace, showing (and by default skipping)
# any with work in progress.
#
# Enumerates every workspace of the current repo via `jj workspace list`, so it
# covers all of them wherever they live -- including the default/main-repo
# workspace. Run it from inside any workspace of the repo.
#
#   jj-refresh-workspaces          refresh clean workspaces; SKIP WIP ones,
#                                  showing a --stat of each one's changes.
#   jj-refresh-workspaces -p       for WIP workspaces, show the full diff (-p /
#                                  --patch) instead of just --stat.
#   jj-refresh-workspaces -f       ALSO refresh WIP workspaces (-f / --force).
#
# Per workspace:
#   * @ empty                -> `jj workspace update-stale` (refresh; no-op if
#                              already current).
#   * @ has changes, CURRENT -> `ok (has WIP)`: nothing to refresh; work left as-is.
#   * @ has changes, STALE   -> default: skip + show the diff (run -f to refresh).
#                               --force: update-stale rebases the change onto the
#                               refreshed history; a clash becomes an in-commit
#                               conflict, never a loss -- `jj op restore` undoes all.
#
# Mechanics: state (empty vs WIP) is read with `--ignore-working-copy`, which works
# even when the workspace is STALE -- the case that matters, since a rewrite leaves
# every other workspace stale. A best-effort `jj status` first snapshots on-disk
# edits into @ when the workspace is current; jj refuses to snapshot a stale
# workspace, so that step is simply skipped for it and update-stale (what it needs)
# still runs. All per-workspace jj calls `cd` into the workspace -- `jj -R
# <workspace>` errors on a stale workspace and does not reliably target its @.
#
# It ends with a brew-doctor-style "next steps" summary of anything still needing a
# hand: broken paths, stale+WIP workspaces to -f, uncommitted work to commit, and
# conflicted commits to resolve -- or an all-clear when there's nothing.
#
# BLIND SPOT: on-disk edits made in a workspace while it is ALREADY stale were
# never snapshotted (stale blocks it) and update-stale overwrites them. Snapshot a
# workspace (run any jj command in it) BEFORE it goes stale -- jj-catch-up does
# this in its pre-rebase pass.
set -eu

show=stat
force=0
usage() { awk 'NR==1{next} !/^#/{exit} {sub(/^# ?/,""); print}' "$0"; }

while [ $# -gt 0 ]; do
    case "$1" in
        -p|--patch) show=patch; shift ;;
        -f|--force) force=1; shift ;;
        -h|--help)  usage; exit 0 ;;
        --) shift; break ;;
        -*) printf 'jj-refresh-workspaces: unknown option: %s\n' "$1" >&2; exit 2 ;;
        *) break ;;
    esac
done

TAB=$(printf '\t')

# Command to suggest for the -f re-run. jj-catch-up overrides this (via env) so
# the tip names the command the user actually ran, not this inner tool.
FIX_CMD="${JJRW_FIX_CMD:-jj-refresh-workspaces}"

# Show a WIP workspace's recorded @ change: --stat by default, full diff with -p.
_show_wip() {  # $1 = workspace root; cd in so paths render workspace-relative
    if [ "$show" = patch ]; then
        ( cd "$1" && jj --ignore-working-copy diff -r @ ) 2>/dev/null | sed 's/^/               /'
    else
        ( cd "$1" && jj --ignore-working-copy diff -r @ --stat ) 2>/dev/null | sed 's/^/               /'
    fi
}

ws_list=$(jj workspace list --ignore-working-copy \
              -T 'name ++ "\t" ++ root ++ "\n"' 2>/dev/null) || {
    echo "jj-refresh-workspaces: run this from inside a jj repo/workspace." >&2
    exit 1
}
[ -n "$ws_list" ] || { echo "jj-refresh-workspaces: no workspaces found." >&2; exit 1; }

# Loop over a temp file (not a `cmd | while` pipe) so the accumulated tip-lists
# survive to the summary below -- a pipe subshell would discard them.
tmp=$(mktemp) || { echo "jj-refresh-workspaces: mktemp failed." >&2; exit 1; }
trap 'rm -f "$tmp"' EXIT INT TERM
printf '%s\n' "$ws_list" > "$tmp"

bad_path=""      # unreachable recorded path -> forget + re-add
wip_stale=""     # stale + WIP, skipped -> needs -f
wip_current=""   # current + WIP -> commit or discard when ready

while IFS="$TAB" read -r name root; do
    [ -n "${name:-}" ] || continue

    # Unreachable recorded path (missing/unresolvable "<Error ...>").
    if [ ! -d "$root" ]; then
        printf '  skip(bad-path) %-28s %s\n' "$name" "$root" >&2
        bad_path="$bad_path $name"
        continue
    fi

    # Best-effort snapshot: captures on-disk edits into @ when current. jj refuses
    # to snapshot a STALE workspace, so success/failure doubles as the stale check.
    if ( cd "$root" && jj status >/dev/null 2>&1 ); then stale=0; else stale=1; fi

    # Read the recorded @ WITHOUT snapshotting -- works even when stale.
    state=$( cd "$root" && jj --ignore-working-copy log --no-graph -r @ \
                 -T 'if(empty, "clean", "wip")' 2>/dev/null || echo err )

    case "$state" in
        err)
            printf '  skip(?)    %-28s could not read @ (dead? `jj workspace forget %s`)\n' "$name" "$name" >&2 ;;
        clean)
            out=$( cd "$root" && jj workspace update-stale 2>&1 || true )
            case "$out" in
                *"not stale"*|*"Nothing changed"*|"") printf '  ok         %-28s up to date\n' "$name" ;;
                *)                                     printf '  refreshed  %-28s\n' "$name" ;;
            esac ;;
        wip)
            if [ "$stale" -eq 0 ]; then
                printf '  ok         %-28s up to date (has WIP)\n' "$name"
                wip_current="$wip_current $name"
            elif [ "$force" -eq 1 ]; then
                printf '  refreshed  %-28s (was stale + WIP -- rebased onto refresh)\n' "$name"
                _show_wip "$root"
                ( cd "$root" && jj workspace update-stale 2>&1 | sed 's/^/               /' ) || true
            else
                printf '  skip(WIP,stale) %-24s stale with changes -- run -f to refresh:\n' "$name" >&2
                _show_wip "$root"
                wip_stale="$wip_stale $name"
            fi ;;
    esac
done < "$tmp"

# --- next steps (brew-doctor style) -----------------------------------------
conflicted=$(jj log --no-graph -r 'conflicts()' \
                 -T 'change_id.shortest() ++ " "' 2>/dev/null || true)

if [ -n "$bad_path$wip_stale$wip_current" ] || [ -n "$conflicted" ]; then
    echo
    echo "next steps:"
    if [ -n "$bad_path" ]; then
        echo "  * broken workspace path (unreachable) -- forget + re-add:"
        for w in $bad_path; do echo "        $w"; done
        echo "      \$ jj workspace forget <name> && jj workspace add --name <name> -r <bookmark> <path>"
        echo
    fi
    if [ -n "$wip_stale" ]; then
        echo "  * stale + uncommitted work (not refreshed):"
        for w in $wip_stale; do echo "        $w"; done
        echo "      \$ $FIX_CMD -f"
        echo
    fi
    if [ -n "$wip_current" ]; then
        echo "  * uncommitted work parked in @ -- commit or discard when ready:"
        for w in $wip_current; do echo "        $w"; done
        echo "      \$ cd <ws> && jj commit -m '...'   # keep"
        echo "      \$ cd <ws> && jj restore <path>    # drop"
        echo
    fi
    if [ -n "$conflicted" ]; then
        echo "  * conflicted commit(s) present -- resolve:"
        for c in $conflicted; do echo "        $c"; done
        echo "      \$ jj log -r 'conflicts()'         # then edit files / jj resolve"
        echo
    fi
else
    echo
    echo "all workspaces clean and current -- nothing to do."
fi
