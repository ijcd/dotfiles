#!/bin/bash
# Quick-index ~/Applications and /Applications for Alfred/Spotlight,
# then restore indexing state based on time-of-day schedule.
#
# Schedule: indexing ON 03:30–08:00, OFF otherwise
# (matches launchd daemons in performance.nix)

set -e

echo "Enabling Spotlight temporarily..."
sudo mdutil -a -i on >/dev/null 2>&1

echo "Indexing applications..."
mdimport ~/Applications /Applications 2>/dev/null

hour=$(date +%-H)
min=$(date +%-M)
now=$((hour * 60 + min))
# 03:30 = 210, 08:00 = 480
if [ "$now" -ge 210 ] && [ "$now" -lt 480 ]; then
  echo "Within indexing window (03:30–08:00), leaving Spotlight on."
else
  echo "Outside indexing window, disabling Spotlight."
  sudo mdutil -a -i off >/dev/null 2>&1
fi

echo "Done."
