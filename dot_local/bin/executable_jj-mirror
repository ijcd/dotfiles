#!/usr/bin/env bash
# jj-mirror — maintain a "prime" bookmark chain as a derived view of a
# "source" (WIP) bookmark chain, so jj-vine pushes clean PRs without
# force-push churn as the WIP side evolves.
#
# See docs/superpowers/specs/2026-07-15-jj-mirror-design.md for the design.

set -euo pipefail

# Requires bash 4+ for associative arrays (declare -A in the orphan cull) and
# safe empty-array expansion. macOS stock /bin/bash is 3.2 — install a modern
# bash (homebrew, nix, macports) before using this tool.
if (( BASH_VERSINFO[0] < 4 )); then
  echo "jj-mirror: bash ${BASH_VERSION} too old — needs bash 4+ (declare -A, safe \${arr[@]+expansion})" >&2
  exit 1
fi

# ─── Help ─────────────────────────────────────────────────────────────────────
# Top-level usage: overview + command index. Per-command help via
# `jj-mirror <cmd> --help` or `jj-mirror help <cmd>`.

usage() {
  cat <<'EOF'
jj-mirror — maintain a clean "prime" bookmark chain as a derived view of a
messy "source" (WIP) chain, so jj-vine pushes stable PRs across resyncs.

Usage:
  jj-mirror [--help]                     show this help
  jj-mirror help <command>               show help for one command
  jj-mirror <command> [--help] [args]    run a command (or its own help)

Commands:
  add        Register a mirror rule (source -> dest [, --squash]).
  rm         Unregister a rule / carve out a bookmark from a glob.
  list       Print the mirror rules.
  sync       Re-derive the prime chain from the current source chain.
  status     Report source→prime pair state per thread (ok/stale/missing). [default]
  push       Sync, then delegate to jj-vine submit --tracked.
  abandon    Delete a matched pair of source and prime bookmarks + commits.
  config     Print the detected configuration (prefixes + roots + rules).

Configuration (jj config, [jj-mirror] section):
  source-prefix    Source-side bookmark prefix (default "wip/").
  prime-prefix     Prime-side bookmark prefix (default "pr/").
                   Must not overlap. Empty prefix is allowed but matches
                   every bookmark; use with care.
  source-root      Base the source bookmarks sit on (default local/main,
                   falling back to trunk() where local/main is absent).
  prime-root       Base the prime chain is re-based onto (default trunk()=master).
  roots.<pair>.source / roots.<pair>.prime
                   Per-pair root override, keyed by the thread's leaf (tip)
                   bookmark suffix; falls back to source-root / prime-root.
                   So different pairs can sit on and target different bases, e.g.
                     jj config set --repo jj-mirror.roots.feat-a.prime "release/1.2"

Model:
  Rules (jj-mirror add) opt bookmarks in; the most-specific matching rule wins.
  For each included source bookmark's thread, the WHOLE branch source-root..tip
  is replayed commit-for-commit onto the prime root (re-based, base stripped),
  and dest bookmarks land on the mirrored commits — so a stacked source mirrors
  to a stacked dest, and a tip-only bookmark mirrors its whole branch. A --squash
  rule collapses a branch to one cumulative dest commit instead. Re-derived from
  the current graph each sync; unchanged prefixes stay put (PR stability).

      SOURCE  (wip/*)                      PRIME  (pr/*)
      sits on local/main                   re-based onto master
                          ══ mirror ══▶
        ● wip/feat-c ┐                     ┌ ● pr/feat-c
        │            │   each commit's     │ │
        ● wip/feat-b ┤   own diff,         ┤ ● pr/feat-b
        │            │   strict            │ │
        ● wip/feat-a ┘   cherry-pick       └ ● pr/feat-a
        │                                    │
        ● local/main   ✂ extra base          │
        │                 stripped           │
        ● master ────────────────────────────● master  (trunk)

Example:
  jj bookmark set wip/feature-a -r @-
  jj-mirror sync              # creates pr/feature-a
  jj-mirror status            # reports "ok"
  jj-mirror push              # sync + jj-vine submits the PR

See:
  spec  docs/superpowers/specs/2026-07-15-jj-mirror-design.md
  jj-vine  https://codeberg.org/abrenneke/jj-vine
EOF
}

help_sync() {
  cat <<'EOF'
Usage:
  jj-mirror sync [-n|--dry-run] [-t|--thread <bookmark>]

Re-derive the prime chain from the current source chain. State-free: the
whole shape is computed from the current jj graph each invocation.

Options:
  -n, --dry-run
        Print intended actions per thread without mutating the repo. Includes
        an orphan-cull preview and marks downstream commits as "(cascade)"
        when their parent moves even if their own diff didn't change.

  -t, --thread <bookmark>
        Limit sync to the single thread containing <bookmark>. Match is exact
        and must include the source prefix (e.g. "wip/foo", not "foo"). Under
        --thread, the orphan cull is skipped entirely so other threads' prime
        bookmarks are not deleted. A filter that matches zero threads prints
        a warning to stderr.

Behavior:
  For each thread (a linear chain of source bookmarks descending from trunk()):
    1. The whole branch source-root..tip is replayed commit-for-commit onto the
       prime root — every commit, not just bookmarked ones — and dest bookmarks
       land on the mirrored commits. A --squash rule collapses it to one commit.
    2. Prime bookmarks whose suffix has no matching source bookmark in ANY
       thread are abandoned (repo-wide orphan cull; skipped under --thread).
    3. Prime commits already matching parent + diff-hash are left in place —
       the "no-op path". This is what keeps jj-vine PRs stable across resyncs.
    4. A thread whose cherry-pick conflicts is rolled back to its own
       pre-thread savepoint and skipped (reported to stderr); the clean
       threads still sync. jj refuses to `git push` a conflicted commit, so a
       conflicted prime could never become a PR — fix the source thread's base
       instead. Sync exits non-zero if any thread was skipped.

Preconditions (enforced at startup, exit 2 on violation):
  - No two source bookmarks on the same commit (ambiguous pairing).
  - Every trunk()..<source> range must be linear (no merges).

Exit codes:
  0    all threads mirrored (or dry-run completed)
  1    a thread hit a runtime error — that thread rolled back, others synced
  2    a thread conflicted (rolled back, others synced), OR a precondition
       failed before any sync (ambiguous pairing, non-linear thread, bad arg)
EOF
}

help_status() {
  cat <<'EOF'
Usage:
  jj-mirror status [-g|--graph]

Read-only report of every source→prime pair, grouped by thread. With
-g/--graph, render a graph grouped by source root then prime root, so threads
sharing a base coalesce under one edge (a root is marked * when it differs from
the default).

Output per line:
  <source-name> -> <prime-name>    [state]

States:
  ok       Prime exists and its diff matches the source diff.
  stale    Prime exists but the two diffs differ (sync would rebuild).
  missing  No prime bookmark for this source suffix (sync would create).

Preconditions (enforced at startup, exit 2 on violation):
  - No two source bookmarks on the same commit.
  - Every trunk()..<source> range must be linear.

Exit codes:
  0    reported successfully
  2    validation error
EOF
}

help_push() {
  cat <<'EOF'
Usage:
  jj-mirror push

Run `sync`, then delegate to jj-vine to submit the prime chain as PRs.
jj-vine is looked up in this order:
  1. Standalone `jj-vine` binary on PATH.
  2. `jj vine …` subcommand plugin (via `jj vine --help`).

If jj-vine is not installed, prints an install hint and exits 1 AFTER a
successful sync.

Exit codes:
  0    sync + push both succeeded (replaced by jj-vine's own exit code via exec)
  1    sync succeeded but jj-vine not found
  Other  sync failure — see `jj-mirror sync --help`
EOF
}

help_abandon() {
  cat <<'EOF'
Usage:
  jj-mirror abandon <name>

Delete both the source bookmark <source-prefix><name> and the prime bookmark
<prime-prefix><name>, and abandon their underlying commits.

Idempotent: missing bookmarks are OK; a second invocation is a no-op.
Atomic: wraps in the same `capture_pre_op` + `jj op restore` envelope as
sync, so any failure leaves the repo at its pre-abandon state.

Arguments:
  <name>    The pair suffix (no prefix). Example: for wip/feature-a and
            pr/feature-a, run `jj-mirror abandon feature-a`.

Exit codes:
  0    completed (or nothing to do)
  1    runtime error (rolled back)
  2    missing <name> argument
EOF
}

help_config() {
  cat <<'EOF'
Usage:
  jj-mirror config

Print the detected configuration — bookmark prefixes, source/prime roots (each
with the commit it resolves to), and the mirror rules. Read-only.
EOF
}

help_add() {
  cat <<'EOF'
Usage:
  jj-mirror add <source> [<dest>] [--squash]

Register a mirror rule. <source> and <dest> are bookmark patterns; a trailing
'*' is a prefix glob (any depth). Only bookmarks matched by a rule are mirrored
(explicit opt-in). The MOST-SPECIFIC matching rule wins (exact > longer-prefix
glob), so a rename or --squash on one branch rides on top of a family glob.

  jj-mirror add 'wip/*' 'ijcd/*'             # family: wip/X -> ijcd/X (live)
  jj-mirror add 'wip/foo' 'ijcd/foo-mirror'  # rename
  jj-mirror add 'wip/bar'                     # dest from <prime-prefix>
  jj-mirror add 'wip/baz' --squash            # collapse the branch to one commit

--squash mirrors the branch as a single cumulative commit; the default mirrors
it commit-for-commit (stacked source -> stacked dest). See also `jj-mirror rm`.
EOF
}

help_rm() {
  cat <<'EOF'
Usage:
  jj-mirror rm <source>

Guarantee <source> will not mirror. Deletes an exact rule if one names it; if a
broader glob still covers a concrete bookmark, writes an exclusion carve-out
(more specific than the glob, so it wins). `add <source>` reverses it.
EOF
}

help_list() {
  cat <<'EOF'
Usage:
  jj-mirror list

Print the mirror rules (name, source -> dest, flags). Read-only.
EOF
}

# config_main — print the detected config (prefixes + roots + what they resolve to).
config_main() {
  local sr pr
  sr=$(jj log --no-graph -r "$SOURCE_ROOT" -T 'commit_id.short() ++ if(bookmarks, " " ++ bookmarks, "")' 2>/dev/null | head -n1)
  pr=$(jj log --no-graph -r "$PRIME_ROOT"  -T 'commit_id.short() ++ if(bookmarks, " " ++ bookmarks, "")' 2>/dev/null | head -n1)
  printf 'jj-mirror config (detected):\n'
  printf '  source-prefix   %s\n' "$SOURCE_PREFIX"
  printf '  prime-prefix    %s\n' "$PRIME_PREFIX"
  printf '  source-root     %s  ->  %s\n' "$SOURCE_ROOT" "${sr:-<unresolved>}"
  printf '  prime-root      %s  ->  %s\n' "$PRIME_ROOT" "${pr:-<unresolved>}"

  # Per-pair overrides (jj-mirror.roots.<pair>.{source,prime}), if any.
  local overrides
  overrides=$(jj config list jj-mirror.roots 2>/dev/null || true)
  if [[ -n "$overrides" ]]; then
    printf '  per-pair overrides:\n'
    printf '%s\n' "$overrides" | sed 's/^jj-mirror\.roots\./    /'
  fi

  # Mirror rules (seeded default shown when none configured).
  ensure_rules
  printf '  rules (most-specific wins):\n'
  local i rflags
  for (( i=0; i<${#R_SRC[@]}; i++ )); do
    rflags=""
    [[ "${R_MIRROR[i]}" == "false" ]] && rflags+=" EXCLUDE"
    [[ "${R_SQUASH[i]}" == "true"  ]] && rflags+=" squash"
    printf '    %-14s %-14s -> %s%s\n' "${R_NAME[i]}" "${R_SRC[i]}" "${R_DEST[i]:-<default>}" "$rflags"
  done
}

# print_help TOPIC — dispatch to a per-command help function, or the top-level
# usage. Called from every `--help` / `help` handler so the surface is
# uniform.
print_help() {
  case "${1:-}" in
    ""|jj-mirror) usage ;;
    sync)         help_sync ;;
    status)       help_status ;;
    push)         help_push ;;
    abandon)      help_abandon ;;
    config)       help_config ;;
    add)          help_add ;;
    rm)           help_rm ;;
    list)         help_list ;;
    *) echo "jj-mirror: no help for unknown command '$1'" >&2; usage >&2; return 2 ;;
  esac
}

load_config() {
  SOURCE_PREFIX="$(jj config get jj-mirror.source-prefix 2>/dev/null || echo 'wip/')"
  PRIME_PREFIX="$(jj config get jj-mirror.prime-prefix  2>/dev/null || echo 'pr/')"

  # Bases. Source bookmarks sit on SOURCE_ROOT (default local/main = master + your
  # local-only base); the prime chain is re-based onto PRIME_ROOT (default trunk() =
  # master). Stripping SOURCE_ROOT's extra base is the whole point — it makes the
  # prime chain PR-ready. source-root's default falls back to trunk() where
  # local/main is absent, so generic repos (and the tests) still work.
  SOURCE_ROOT="$(jj config get jj-mirror.source-root 2>/dev/null || echo 'coalesce(present(local/main), trunk())')"
  PRIME_ROOT="$(jj config get jj-mirror.prime-root  2>/dev/null || echo 'trunk()')"

  if [[ "$SOURCE_PREFIX" == "$PRIME_PREFIX" ]]; then
    echo "jj-mirror: source-prefix and prime-prefix must differ" >&2
    exit 2
  fi
  # neither may be a prefix of the other
  if [[ -n "$SOURCE_PREFIX" && "$PRIME_PREFIX" == "$SOURCE_PREFIX"* ]] \
  || [[ -n "$PRIME_PREFIX"  && "$SOURCE_PREFIX" == "$PRIME_PREFIX"*  ]]; then
    echo "jj-mirror: source-prefix ($SOURCE_PREFIX) and prime-prefix ($PRIME_PREFIX) must not overlap" >&2
    exit 2
  fi

  # Load the rule registry in THIS (main) process so R_* arrays persist for
  # functions called via $() / process-substitution subshells (which inherit but
  # cannot export them back).
  load_rules
}

# list_bookmarks_with_prefix PREFIX
# Emits: <name>\t<short-commit-id> per line, filtered by PREFIX.
# Empty PREFIX matches every bookmark.
list_bookmarks_with_prefix() {
  local prefix=$1
  # Template: name TAB short commit_id NEWLINE, for LOCAL bookmarks with a single
  # target only. if(remote, ...) drops the diverged `name@git` remote-tracking
  # rows a colocated git repo surfaces (same name, different target) so a bookmark
  # isn't listed — and mirrored — twice. if(normal_target, ...) drops rows with no
  # single local commit — a bookmark deleted-locally-but-present-on-remote, or a
  # conflicted/divergent one — whose commit_id() would otherwise render an error
  # string and crash a downstream `jj abandon` (orphan cull).
  jj bookmark list -T 'if(remote, "", if(normal_target, name ++ "\t" ++ normal_target.commit_id().short() ++ "\n", ""))' 2>/dev/null \
    | while IFS=$'\t' read -r name cid; do
        [[ -n "$name" && -n "$cid" ]] || continue
        if [[ -z "$prefix" || "$name" == "$prefix"* ]]; then
          printf '%s\t%s\n' "$name" "$cid"
        fi
      done
}

DRY_RUN=0
THREAD_FILTER=""

# parse_sync_flags — pull -n/--dry-run and -t/--thread out of "$@" as globals.
# Rejects unknown positionals: `sync` takes no positional args, so anything
# left over is a typo. (Previously silently discarded — a footgun.)
parse_sync_flags() {
  while (( $# )); do
    case "$1" in
      -n|--dry-run) DRY_RUN=1; shift ;;
      -t|--thread)  THREAD_FILTER=${2:-}; shift 2 ;;
      --thread=*)   THREAD_FILTER=${1#--thread=}; shift ;;
      *)
        echo "jj-mirror: sync: unknown argument '$1'" >&2
        exit 2
        ;;
    esac
  done
}

list_all_bookmarks() { list_bookmarks_with_prefix ""; }

# list_source_bookmarks — local single-target bookmarks that an include rule
# opts in (mirror != false). Replaces the old prefix filter; the seeded default
# rule (<source-prefix>*) reproduces it.
list_source_bookmarks() {
  ensure_rules
  local name cid
  while IFS=$'\t' read -r name cid; do
    is_included "$name" && printf '%s\t%s\n' "$name" "$cid"
  done < <(list_all_bookmarks)
  return 0
}

# list_prime_bookmarks — the mirror-MANAGED set: bookmarks matching any include
# rule's dest pattern (dest omitted ⇒ <prime-prefix>*). These are the outputs the
# orphan cull is allowed to remove.
list_prime_bookmarks() {
  ensure_rules
  local name cid i destpat matched
  while IFS=$'\t' read -r name cid; do
    matched=0
    for (( i=0; i<${#R_DEST[@]}; i++ )); do
      [[ "${R_MIRROR[i]}" != "false" ]] || continue
      destpat=${R_DEST[i]}; [[ -n "$destpat" ]] || destpat="${PRIME_PREFIX}*"
      if pattern_match "$destpat" "$name"; then matched=1; break; fi
    done
    (( matched )) && printf '%s\t%s\n' "$name" "$cid"
  done < <(list_all_bookmarks)
  return 0
}

strip_source_prefix() { printf '%s' "${1#"$SOURCE_PREFIX"}"; }
strip_prime_prefix()  { printf '%s' "${1#"$PRIME_PREFIX"}";  }

# ─── Rule registry ─────────────────────────────────────────────────────────
# Mirror rules opt bookmarks in explicitly (jj config [jj-mirror.rules.<name>]):
#   source (pattern, required)   dest (pattern; omitted ⇒ <prime-prefix>+suffix)
#   squash (bool)   mirror (bool; false = exclusion)   source-root / prime-root
# A bookmark's behaviour is set by the MOST-SPECIFIC matching rule
# (exact > longer-prefix glob). With no rules configured, an in-memory default
# (<source-prefix>* -> <prime-prefix>*) is seeded so prefix-only setups keep
# working with zero `add`s. '*' is a prefix glob (matches any depth).
RULES_LOADED=0
declare -a R_NAME R_SRC R_DEST R_SQUASH R_MIRROR R_SROOT R_PROOT

# rule_names — configured rule names (empty if none).
rule_names() {
  jj config list jj-mirror.rules 2>/dev/null \
    | sed -n 's/^jj-mirror\.rules\.\([^.]*\)\..*/\1/p' | awk '!seen[$0]++'
}

load_rules() {
  R_NAME=(); R_SRC=(); R_DEST=(); R_SQUASH=(); R_MIRROR=(); R_SROOT=(); R_PROOT=()
  local names name
  names=$(rule_names)
  if [[ -z "$names" ]]; then
    R_NAME+=("default"); R_SRC+=("${SOURCE_PREFIX}*"); R_DEST+=("${PRIME_PREFIX}*")
    R_SQUASH+=("false"); R_MIRROR+=("true"); R_SROOT+=(""); R_PROOT+=("")
    RULES_LOADED=1; return 0
  fi
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    R_NAME+=("$name")
    R_SRC+=("$(jj config get "jj-mirror.rules.$name.source" 2>/dev/null || echo '')")
    R_DEST+=("$(jj config get "jj-mirror.rules.$name.dest" 2>/dev/null || echo '')")
    R_SQUASH+=("$(jj config get "jj-mirror.rules.$name.squash" 2>/dev/null || echo 'false')")
    R_MIRROR+=("$(jj config get "jj-mirror.rules.$name.mirror" 2>/dev/null || echo 'true')")
    R_SROOT+=("$(jj config get "jj-mirror.rules.$name.source-root" 2>/dev/null || echo '')")
    R_PROOT+=("$(jj config get "jj-mirror.rules.$name.prime-root" 2>/dev/null || echo '')")
  done <<< "$names"
  RULES_LOADED=1
}
ensure_rules() { (( RULES_LOADED )) || load_rules; }

# pattern_match PATTERN NAME — exact, or trailing-'*' prefix glob.
pattern_match() {
  local pat=$1 name=$2
  if [[ "$pat" == *'*' ]]; then local pre=${pat%\*}; [[ "$name" == "$pre"* ]]
  else [[ "$name" == "$pat" ]]; fi
}
# pattern_spec PATTERN — higher = more specific. exact ≫ glob; longer prefix wins.
pattern_spec() {
  local pat=$1
  if [[ "$pat" == *'*' ]]; then local pre=${pat%\*}; printf '%s' "${#pre}"
  else printf '%s' "$(( 100000 + ${#pat} ))"; fi
}
# resolve_rule_idx BM — index of the most-specific matching rule, or -1.
resolve_rule_idx() {
  ensure_rules
  local bm=$1 best=-1 bestspec=-1 i spec
  for (( i=0; i<${#R_SRC[@]}; i++ )); do
    [[ -n "${R_SRC[i]}" ]] || continue
    pattern_match "${R_SRC[i]}" "$bm" || continue
    spec=$(pattern_spec "${R_SRC[i]}")
    (( spec > bestspec )) && { bestspec=$spec; best=$i; }
  done
  printf '%s' "$best"
}
# is_included BM — true if the winning rule mirrors it (not an exclusion).
is_included() {
  local idx; idx=$(resolve_rule_idx "$1"); (( idx >= 0 )) || return 1
  [[ "${R_MIRROR[idx]}" != "false" ]]
}
# dest_for BM — the mirror bookmark name for BM under its winning rule.
dest_for() {
  ensure_rules
  local bm=$1 i spec best=-1 bestspec=-1 db=-1 dbspec=-1
  for (( i=0; i<${#R_SRC[@]}; i++ )); do
    [[ -n "${R_SRC[i]}" ]] || continue
    pattern_match "${R_SRC[i]}" "$bm" || continue
    spec=$(pattern_spec "${R_SRC[i]}")
    (( spec > bestspec )) && { bestspec=$spec; best=$i; }
    if [[ -n "${R_DEST[i]}" ]] && (( spec > dbspec )); then dbspec=$spec; db=$i; fi
  done
  (( best >= 0 )) || { printf ''; return; }
  # A more-specific rule that omits `dest` INHERITS the dest mapping of the
  # most-specific matching rule that sets one — so `add wip/hotfix --squash` on top
  # of a `wip/* -> ijcd/*` family yields ijcd/hotfix, not the global-prefix default.
  if (( db >= 0 )); then
    local src=${R_SRC[db]} dest=${R_DEST[db]}
    if [[ "$dest" == *'*' && "$src" == *'*' ]]; then
      local spre=${src%\*} dpre=${dest%\*}; printf '%s' "${dpre}${bm#"$spre"}"
    else printf '%s' "$dest"; fi
    return
  fi
  # No matching rule sets a dest → global prime-prefix + the bookmark's source
  # suffix. Use strip_source_prefix, NOT `${pattern%\*}`: an exact rule's pattern
  # has no trailing '*', so stripping it would drop the whole name and yield a bare
  # "$PRIME_PREFIX" (colliding across rules). e.g. `add wip/bar` → pr/bar.
  printf '%s' "${PRIME_PREFIX}$(strip_source_prefix "$bm")"
}
# rule_squash_for BM — "true" if the winning rule squashes.
rule_squash_for() {
  local idx; idx=$(resolve_rule_idx "$1"); (( idx >= 0 )) || { printf 'false'; return; }
  [[ "${R_SQUASH[idx]}" == "true" ]] && printf 'true' || printf 'false'
}

# resolve_source_root / resolve_prime_root LEAF (full bookmark name) — the base
# for LEAF's thread: the winning rule's root override, else the legacy per-pair
# override (jj-mirror.roots.<suffix>.{source,prime}), else the global default.
resolve_source_root() {
  local bm=$1 idx sfx; idx=$(resolve_rule_idx "$bm")
  if (( idx >= 0 )) && [[ -n "${R_SROOT[idx]}" ]]; then printf '%s' "${R_SROOT[idx]}"; return; fi
  sfx=$(strip_source_prefix "$bm")
  jj config get "jj-mirror.roots.${sfx}.source" 2>/dev/null || printf '%s' "$SOURCE_ROOT"
}
resolve_prime_root() {
  local bm=$1 idx sfx; idx=$(resolve_rule_idx "$bm")
  if (( idx >= 0 )) && [[ -n "${R_PROOT[idx]}" ]]; then printf '%s' "${R_PROOT[idx]}"; return; fi
  sfx=$(strip_source_prefix "$bm")
  jj config get "jj-mirror.roots.${sfx}.prime" 2>/dev/null || printf '%s' "$PRIME_ROOT"
}

# range_diff_hash FROM TO — SHA-256 of the cumulative git diff FROM..TO (used by
# squash no-op detection).
range_diff_hash() {
  local from=$1 to=$2 patch
  patch=$(jj diff --from "$from" --to "$to" --git) || return 1
  printf '%s' "$patch" | shasum -a 256 | awk '{print $1}'
}

# render_root REVSET — a friendly one-token label for a root: the local bookmark
# name on the commit it resolves to, else the revset as written. So a base reads
# as `local/main` rather than the raw `coalesce(...)` default, while `trunk()`
# (no local bookmark) stays `trunk()`.
render_root() {
  local bm
  bm=$(jj log --no-graph -r "$1" -T 'local_bookmarks.map(|b| b.name()).join(",")' 2>/dev/null | head -n1)
  if [[ -n "$bm" ]]; then printf '%s' "$bm"; else printf '%s' "$1"; fi
}

# diff_hash REVSET
# Emit SHA-256 hex of the patch text of the revision's own diff.
# Uses -T "" to strip commit metadata; -p emits the diff.
#
# Capture jj's output before hashing so a jj failure returns non-zero instead
# of silently producing the SHA of empty input (the "up-to-date" comparison in
# sync would then treat two failed hashes as equal — a nasty false-positive).
diff_hash() {
  local rev=$1 patch
  # --git: force git-unified format regardless of the user's ui.diff-formatter.
  # range_diff_hash also forces --git; the two are compared against each other in
  # the squash no-op check and squash status, so both MUST use the same format or
  # a machine without a `:git` default silently rebuilds every squash thread.
  patch=$(jj log --no-graph -r "$rev" -T '""' -p --git) || return 1
  printf '%s' "$patch" | shasum -a 256 | awk '{print $1}'
}

# list_source_threads
# Emits one line per thread: <leaf>\t<b1>|<b2>|...|<leaf>
# Algorithm:
#   1. Collect all source bookmarks with their commit ids.
#   2. For each pair, check ancestry via revset (descendants()).
#   3. Leaves = bookmarks with no source-bookmark descendant.
#   4. For each leaf, walk trunk()..leaf & bookmarks() in ancestry order,
#      picking out only source-prefixed names at each commit.
list_source_threads() {
  local -a names cids
  while IFS=$'\t' read -r name cid; do
    names+=("$name"); cids+=("$cid")
  done < <(list_source_bookmarks)

  local n=${#names[@]}
  (( n > 0 )) || return 0

  # For each candidate leaf L, ensure no other source bookmark has L as ancestor.
  # Exclude L itself from the descendants check — otherwise two bookmarks on the
  # same commit would each see the other as a "descendant" and neither picked as
  # leaf (thread silently vanishes). (Same-commit collisions are already caught
  # upstream by validate_source_bookmarks_or_die, but this stays safe if the
  # validator is bypassed.)
  local i j leaf other
  for (( i=0; i<n; i++ )); do
    leaf=${names[i]}
    local is_leaf=1
    for (( j=0; j<n; j++ )); do
      (( i == j )) && continue
      other=${names[j]}
      # Is 'other' a descendant of 'leaf' (excluding L itself)? If so, leaf isn't a leaf.
      if jj log --no-graph -r "(descendants(\"$leaf\") ~ \"$leaf\") & \"$other\"" \
              -T 'commit_id.short() ++ "\n"' 2>/dev/null | grep -q .; then
        is_leaf=0; break
      fi
    done
    (( is_leaf )) || continue

    # Walk the ordered chain from trunk toward leaf.
    # jj log with a revset prints in reverse-chronological order (newest first);
    # we want oldest first, so reverse portably via awk. (macOS `tail -r` and
    # GNU `tac` both exist but neither is universal.)
    # Template note: local_bookmarks.map(|b| b.name()).join(",") verified working
    # against jj 0.43.0 — emits comma-joined names for multi-bookmark commits.
    local sroot chain
    sroot=$(resolve_source_root "$leaf")
    chain=$(
      jj log --no-graph -r "$sroot..\"$leaf\" & bookmarks()" \
        -T 'local_bookmarks.map(|b| b.name()).join(",") ++ "\n"' 2>/dev/null \
      | awk 'NF' \
      | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--)print a[i]}'
    )

    # Each line may have multiple source-prefixed names comma-separated if a commit
    # carries several source bookmarks. Split, filter, join with |.
    local ordered=""
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      IFS=',' read -ra parts <<< "$line"
      local part
      for part in "${parts[@]}"; do
        if is_included "$part"; then
          ordered+="${ordered:+|}$part"
        fi
      done
    done <<< "$chain"

    printf '%s\t%s\n' "$leaf" "$ordered"
  done
}

# validate_source_bookmarks_or_die — enforce the spec's shape invariants for
# source threads. Exits 2 (config-error tier) on violation.
#
# Rejects, per spec's "Failure modes" table:
#   - Two source bookmarks on the same commit (ambiguous pairing).
#   - Non-linear source thread — a merge commit anywhere in trunk()..leaf.
#
# This runs BEFORE sync_main or status_main mutates or reports; anything
# downstream can trust the graph is a set of disjoint linear chains.
validate_source_bookmarks_or_die() {
  local -a names cids
  while IFS=$'\t' read -r name cid; do
    names+=("$name"); cids+=("$cid")
  done < <(list_source_bookmarks)

  local n=${#names[@]}
  (( n > 0 )) || return 0

  # 1. Same-commit ambiguity — pairwise scan on commit id.
  local i j
  for (( i=0; i<n; i++ )); do
    for (( j=i+1; j<n; j++ )); do
      if [[ "${cids[i]}" == "${cids[j]}" ]]; then
        echo "jj-mirror: ambiguous pairing — ${names[i]} and ${names[j]} point to the same commit ${cids[i]}; one source bookmark per commit" >&2
        exit 2
      fi
    done
  done

  # 2. Non-linear threads — merges() intersected with trunk()..bookmark must
  # be empty for every source bookmark. Merges anywhere upstream of a source
  # bookmark within the mine range mean the chain from trunk isn't a single
  # path.
  local nm nmroot
  for nm in "${names[@]}"; do
    nmroot=$(resolve_source_root "$nm")
    if jj log --no-graph -r "merges() & $nmroot..\"$nm\"" -T 'commit_id ++ "\n"' 2>/dev/null \
       | grep -q .; then
      echo "jj-mirror: non-linear source thread — merge commit found between the source root and $nm; only linear chains are supported in v1" >&2
      exit 2
    fi
  done
}

# capture_pre_op — echo the current jj op id, to feed jj op restore on failure.
capture_pre_op() {
  jj op log --limit 1 --no-graph -T 'id ++ "\n"' 2>/dev/null | head -n1
}

# find_prime_bookmark NAME — echo the commit id of <prime-prefix>NAME, or empty.
find_prime_bookmark() {
  local name=$1
  local full="${PRIME_PREFIX}${name}"
  jj log --no-graph -r "$full" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true
}

# range_commits SROOT LEAF — emit "<short_cid>\t<comma-joined-bookmarks>" for
# every commit in SROOT..LEAF, oldest-first. This is the FULL branch (bookmarked
# or not), the unit the mirror replays.
range_commits() {
  local sroot=$1 leaf=$2
  jj log --no-graph -r "$sroot..\"$leaf\"" \
    -T 'commit_id.short() ++ "\t" ++ local_bookmarks.map(|b| b.name()).join(",") ++ "\n"' 2>/dev/null \
    | awk 'NF' | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--)print a[i]}'
}

# set_dest_bookmarks CID BMS — for each INCLUDED source bookmark in BMS (comma
# list), set its resolved dest bookmark on CID. Idempotent.
set_dest_bookmarks() {
  local cid=$1 bms=$2 bm dname
  [[ -n "$bms" ]] || return 0
  local -a _arr
  IFS=',' read -ra _arr <<< "$bms"
  for bm in "${_arr[@]}"; do
    is_included "$bm" || continue
    dname=$(dest_for "$bm")
    [[ -n "$dname" ]] || continue
    # --allow-backwards: a rebuilt/re-based prime commit is a sideways move of the
    # dest bookmark, which jj refuses by default.
    jj bookmark set --allow-backwards "$dname" -r "$cid" >/dev/null 2>&1 \
      || { echo "jj-mirror: bookmark set failed for $dname at $cid" >&2; return 1; }
  done
}

# sync_thread LEAF _CHAIN PRIME_ROOT
# Mirror the FULL branch SOURCE_ROOT..LEAF commit-for-commit onto PRIME_ROOT:
# every commit is replayed (a strict cherry-pick of its own diff), and where a
# commit carries an INCLUDED source bookmark its resolved dest bookmark is placed
# on the mirrored commit — so a tip-only bookmark mirrors its whole branch and a
# source stack mirrors to a dest stack. Positional no-op reuse keeps unchanged
# prefixes stable (jj-vine PR stability). Squash mode collapses to one commit.
sync_thread() {
  local leaf=$1
  local prime_root=${3:-$PRIME_ROOT}
  local sroot dleaf squash
  sroot=$(resolve_source_root "$leaf")
  dleaf=$(dest_for "$leaf")
  squash=$(rule_squash_for "$leaf")

  if [[ "$squash" == "true" ]]; then
    squash_thread "$leaf" "$sroot" "$prime_root" "$dleaf"
    return $?
  fi

  # Full branch, oldest-first.
  local -a c_cid=() c_bm=()
  local _cid _bms
  while IFS=$'\t' read -r _cid _bms; do
    [[ -n "$_cid" ]] || continue
    c_cid+=("$_cid"); c_bm+=("$_bms")
  done < <(range_commits "$sroot" "$leaf")
  local n=${#c_cid[@]}
  (( n > 0 )) || return 0

  # Existing prime chain (oldest-first) for positional no-op reuse.
  local -a e_cid=()
  local dleaf_cid ecid
  dleaf_cid=$(jj log --no-graph -r "$dleaf" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
  if [[ -n "$dleaf_cid" ]]; then
    while IFS= read -r ecid; do
      [[ -n "$ecid" ]] && e_cid+=("$ecid")
    done < <(jj log --no-graph -r "$prime_root..$dleaf_cid" -T 'commit_id.short() ++ "\n"' 2>/dev/null \
             | awk 'NF' | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--)print a[i]}')
  fi

  local prev
  prev=$(jj log --no-graph -r "$prime_root" -T 'commit_id.short() ++ "\n"' | head -n1)

  local cascade=0 i scid bms existing e_parent e_hash s_hash new_cid out cflag
  for (( i=0; i<n; i++ )); do
    scid=${c_cid[i]}; bms=${c_bm[i]}
    existing=""
    (( i < ${#e_cid[@]} )) && existing=${e_cid[i]}

    if [[ $cascade -eq 0 && -n "$existing" ]]; then
      e_parent=$(jj log --no-graph -r "$existing-" -T 'commit_id.short() ++ "\n"' | head -n1)
      e_hash=$(diff_hash "$existing") \
        || { echo "jj-mirror: diff_hash failed on existing prime $existing" >&2; return 1; }
      s_hash=$(diff_hash "$scid") \
        || { echo "jj-mirror: diff_hash failed on source $scid" >&2; return 1; }
      if [[ "$e_parent" == "$prev" && "$e_hash" == "$s_hash" ]]; then
        # up-to-date — keep the existing prime commit, just ensure bookmarks.
        set_dest_bookmarks "$existing" "$bms" || return 1
        prev=$existing
        continue
      fi
    fi

    # (Re)build: strict cherry-pick of this commit's own diff onto prev.
    # jj 0.43.0's `duplicate` has no -T flag; parse "Duplicated <old> as
    # <change> <commit_id> <desc>" — field 5 is the new short commit id.
    out=$(jj duplicate "$scid" --destination "$prev" 2>&1)
    new_cid=$(printf '%s\n' "$out" | awk '/^Duplicated/ {print $5; exit}')
    [[ -n "$new_cid" ]] || { echo "jj-mirror: duplicate produced no commit for $scid" >&2; return 1; }
    set_dest_bookmarks "$new_cid" "$bms" || return 1

    # Bookmark BEFORE the conflict check; a conflicted commit triggers `return 2`
    # → sync_main's per-thread `jj op restore` atomically unwinds it.
    cflag=$(jj log --no-graph -r "$new_cid" -T 'if(conflict, "y", "n") ++ "\n"' 2>/dev/null | head -n1)
    if [[ "$cflag" == "y" ]]; then
      echo "jj-mirror: conflict cherry-picking $scid onto ${prev} (prime commit $new_cid)" >&2
      return 2
    fi

    prev=$new_cid
    cascade=1
  done
}

# squash_thread LEAF SROOT PRIME_ROOT DLEAF — collapse the whole branch
# SROOT..LEAF into ONE dest commit = the cumulative diff, re-based onto
# PRIME_ROOT, bookmarked DLEAF. No-op when the existing dest already carries that
# cumulative diff on PRIME_ROOT.
squash_thread() {
  local leaf=$1 sroot=$2 prime_root=$3 dleaf=$4
  local cum existing existing_parent existing_hash proot_cid
  cum=$(range_diff_hash "$sroot" "$leaf") \
    || { echo "jj-mirror: range diff_hash failed for $leaf" >&2; return 1; }
  proot_cid=$(jj log --no-graph -r "$prime_root" -T 'commit_id.short() ++ "\n"' | head -n1)

  existing=$(jj log --no-graph -r "$dleaf" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
  if [[ -n "$existing" ]]; then
    existing_parent=$(jj log --no-graph -r "$existing-" -T 'commit_id.short() ++ "\n"' | head -n1)
    existing_hash=$(diff_hash "$existing") || existing_hash=""
    if [[ "$existing_parent" == "$proot_cid" && "$existing_hash" == "$cum" ]]; then
      return 0   # already the squashed cumulative diff on prime_root
    fi
  fi

  # Duplicate the whole range onto prime_root, then fold into one commit. Track
  # the fold target by CHANGE id (field 4 of "Duplicated <old> as <change>
  # <commit> <desc>") — squash rewrites its commit id, but the change id of the
  # --into commit survives, so it resolves to the folded result.
  local out root_cid tip_cid root_change one
  out=$(jj duplicate "$sroot..\"$leaf\"" --destination "$prime_root" 2>&1)
  root_change=$(printf '%s\n' "$out" | awk '/^Duplicated/ {print $4; exit}')
  root_cid=$(printf '%s\n' "$out" | awk '/^Duplicated/ {print $5; exit}')
  tip_cid=$(printf '%s\n' "$out" | awk '/^Duplicated/ {c=$5} END{print c}')
  [[ -n "$root_change" && -n "$root_cid" && -n "$tip_cid" ]] || { echo "jj-mirror: squash duplicate produced no commits for $leaf" >&2; return 1; }
  if [[ "$root_cid" != "$tip_cid" ]]; then
    jj squash --from "${root_cid}..${tip_cid}" --into "$root_cid" -u >/dev/null 2>&1 \
      || { echo "jj-mirror: squash fold failed for $leaf" >&2; return 1; }
  fi
  one=$(jj log --no-graph -r "$root_change" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1)
  [[ -n "$one" ]] || one=$root_cid
  jj bookmark set --allow-backwards "$dleaf" -r "$one" >/dev/null 2>&1 \
    || { echo "jj-mirror: bookmark set failed for $dleaf at $one" >&2; return 1; }
  local cflag
  cflag=$(jj log --no-graph -r "$one" -T 'if(conflict, "y", "n") ++ "\n"' 2>/dev/null | head -n1)
  if [[ "$cflag" == "y" ]]; then
    echo "jj-mirror: conflict squashing $leaf onto $prime_root (prime commit $one)" >&2
    return 2
  fi
}

# dry_run_thread LEAF CHAIN_STR — print intended actions for one thread
# without mutating anything.
#
# Tracks cascade the same way sync_thread does: once one commit is marked
# create-or-rebuild, every downstream commit's parent moves, so it must
# rebuild too — even if its own diff hasn't changed. Without this, dry-run
# undercounts the real work sync would do.
dry_run_thread() {
  local leaf=$1
  local sroot proot dleaf squash
  sroot=$(resolve_source_root "$leaf")
  proot=$(resolve_prime_root "$leaf")
  dleaf=$(dest_for "$leaf")
  squash=$(rule_squash_for "$leaf")
  printf 'thread %s (dry-run)\n' "$leaf"

  if [[ "$squash" == "true" ]]; then
    if jj log --no-graph -r "$dleaf" -T '""' >/dev/null 2>&1; then
      printf '  would rebuild %s (squash)\n' "$dleaf"
    else
      printf '  would create %s (squash) from %s\n' "$dleaf" "$leaf"
    fi
    return 0
  fi

  local -a c_cid=() c_bm=()
  local _cid _bms
  while IFS=$'\t' read -r _cid _bms; do
    [[ -n "$_cid" ]] || continue
    c_cid+=("$_cid"); c_bm+=("$_bms")
  done < <(range_commits "$sroot" "$leaf")
  local n=${#c_cid[@]}

  local -a e_cid=()
  local dleaf_cid ecid
  dleaf_cid=$(jj log --no-graph -r "$dleaf" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
  if [[ -n "$dleaf_cid" ]]; then
    while IFS= read -r ecid; do [[ -n "$ecid" ]] && e_cid+=("$ecid"); done < <(
      jj log --no-graph -r "$proot..$dleaf_cid" -T 'commit_id.short() ++ "\n"' 2>/dev/null \
      | awk 'NF' | awk '{a[NR]=$0} END{for(i=NR;i>=1;i--)print a[i]}')
  fi

  local prev cascade=0 i scid bms existing e_parent e_hash s_hash bm dname action
  local -a _bmarr
  prev=$(jj log --no-graph -r "$proot" -T 'commit_id.short() ++ "\n"' | head -n1)
  for (( i=0; i<n; i++ )); do
    scid=${c_cid[i]}; bms=${c_bm[i]}
    existing=""; (( i < ${#e_cid[@]} )) && existing=${e_cid[i]}
    if (( cascade )); then
      action="cascade"
    elif [[ -z "$existing" ]]; then
      action="create"; cascade=1
    else
      e_parent=$(jj log --no-graph -r "$existing-" -T 'commit_id.short() ++ "\n"' | head -n1)
      e_hash=$(diff_hash "$existing") || e_hash=""
      s_hash=$(diff_hash "$scid") || s_hash=""
      if [[ "$e_parent" == "$prev" && -n "$s_hash" && "$e_hash" == "$s_hash" ]]; then
        action="keep"; prev=$existing
      else
        action="diff"; cascade=1
      fi
    fi
    [[ -n "$bms" ]] || continue
    IFS=',' read -ra _bmarr <<< "$bms"
    for bm in "${_bmarr[@]}"; do
      is_included "$bm" || continue
      dname=$(dest_for "$bm")
      case "$action" in
        create)  printf '  would create %s from %s\n' "$dname" "$bm" ;;
        cascade) printf '  would rebuild %s (cascade)\n' "$dname" ;;
        diff)    printf '  would rebuild %s (diff changed)\n' "$dname" ;;
        keep)    printf '  would keep %s (up-to-date)\n' "$dname" ;;
      esac
    done
  done
}

# thread_matches_filter LEAF CHAIN_STR — true if THREAD_FILTER is unset, or
# equals the leaf, or appears anywhere in the chain.
thread_matches_filter() {
  local leaf=$1 chain_str=$2
  [[ -n "$THREAD_FILTER" ]] || return 0
  [[ "$leaf" == "$THREAD_FILTER" ]] && return 0
  [[ "|$chain_str|" == *"|$THREAD_FILTER|"* ]]
}

sync_main() {
  validate_source_bookmarks_or_die

  local pre_op rc=0
  pre_op=$(capture_pre_op)
  [[ -n "$pre_op" ]] || { echo "jj-mirror: could not capture pre-sync op id" >&2; exit 1; }

  # Collect all threads up front — used both for the orphan cull (needs the
  # full repo-wide "wanted" set, not just one thread's) and the per-thread walk.
  local -a all_leaves=() all_chains=() leaves=() chains=()
  local leaf chain
  while IFS=$'\t' read -r leaf chain; do
    [[ -n "$leaf" && -n "$chain" ]] || continue
    all_leaves+=("$leaf"); all_chains+=("$chain")
    if thread_matches_filter "$leaf" "$chain"; then
      leaves+=("$leaf"); chains+=("$chain")
    fi
  done < <(list_source_threads)

  # --thread scoping that matches zero threads is almost always a typo. Warn
  # rather than silently claim success — the user thought sync was running.
  if [[ -n "$THREAD_FILTER" && ${#leaves[@]} -eq 0 ]]; then
    echo "jj-mirror: warning — --thread '$THREAD_FILTER' matched 0 of ${#all_leaves[@]} thread(s); nothing to do" >&2
  fi

  if [[ $DRY_RUN -eq 1 ]]; then
    # Preview orphan cull first, under the same repo-wide `wanted` union that
    # the real sync uses. Skipped under --thread (matches real behavior).
    if [[ -z "$THREAD_FILTER" ]]; then
      local -A dry_wanted=()
      local source_name t
      for t in "${all_chains[@]}"; do
        IFS='|' read -ra t_chain <<< "$t"
        for source_name in "${t_chain[@]}"; do
          dry_wanted["$(dest_for "$source_name")"]=1
        done
      done
      local pname pcid
      while IFS=$'\t' read -r pname pcid; do
        if [[ -z "${dry_wanted[$pname]:-}" ]]; then
          printf 'would cull orphan %s\n' "$pname"
        fi
      done < <(list_prime_bookmarks)
    fi

    local i
    for (( i=0; i<${#leaves[@]}; i++ )); do
      dry_run_thread "${leaves[i]}" "${chains[i]}"
    done
    printf 'jj-mirror: dry-run — no changes made\n'
    return 0
  fi

  # Orphan cull: any prime bookmark whose suffix has no corresponding source
  # bookmark in ANY current thread's chain. Computed repo-wide (not per-thread)
  # so culling one thread's leftovers doesn't clobber another thread's live
  # prime bookmarks. Skipped when --thread scopes the sync to a subset, since
  # threads outside the filter must not lose their prime bookmarks.
  if [[ -z "$THREAD_FILTER" ]]; then
    local -A wanted=()
    local source_name t
    for t in "${all_chains[@]}"; do
      IFS='|' read -ra t_chain <<< "$t"
      for source_name in "${t_chain[@]}"; do
        wanted["$(dest_for "$source_name")"]=1
      done
    done

    local pname pcid
    while IFS=$'\t' read -r pname pcid; do
      if [[ -z "${wanted[$pname]:-}" ]]; then
        jj bookmark delete "$pname" >/dev/null 2>&1 \
          || { echo "jj-mirror: orphan cull bookmark delete failed for $pname; rolling back to op $pre_op" >&2; jj op restore "$pre_op" >/dev/null 2>&1 || true; exit 1; }
        jj abandon "$pcid" >/dev/null 2>&1 \
          || { echo "jj-mirror: orphan cull abandon failed for $pcid; rolling back to op $pre_op" >&2; jj op restore "$pre_op" >/dev/null 2>&1 || true; exit 1; }
      fi
    done < <(list_prime_bookmarks)
  fi

  # Per-thread rollback (option 1): each thread gets its own savepoint. A thread
  # whose cherry-pick conflicts is unwound to just before it ran and skipped;
  # clean threads keep their primes. A conflicted commit is never left as a prime
  # — jj refuses to `git push` conflicts, so a conflicted prime could never reach
  # a PR; the fix must land on the source (wip) thread's base. The repo-wide
  # orphan cull above still uses the whole-sync pre_op (atomic with itself, and it
  # runs before any thread).
  local synced=0 failed=0 worst_rc=0 i thread_op proot
  local -a failed_threads=()
  for (( i=0; i<${#leaves[@]}; i++ )); do
    thread_op=$(capture_pre_op)
    rc=0
    proot=$(resolve_prime_root "${leaves[i]}")
    sync_thread "${leaves[i]}" "${chains[i]}" "$proot" || rc=$?
    if [[ $rc -ne 0 ]]; then
      echo "jj-mirror: thread ${leaves[i]} failed (rc=$rc); rolling back this thread to op $thread_op (other threads unaffected)" >&2
      jj op restore "$thread_op" >/dev/null 2>&1 || true
      failed=$((failed + 1))
      failed_threads+=("${leaves[i]}")
      (( rc > worst_rc )) && worst_rc=$rc
      continue
    fi
    synced=$((synced + 1))
  done

  if [[ -n "$THREAD_FILTER" ]]; then
    printf 'jj-mirror: synced %d thread(s) (scoped to %s)\n' "$synced" "$THREAD_FILTER"
  else
    printf 'jj-mirror: synced %d thread(s)\n' "$synced"
  fi
  if (( failed > 0 )); then
    printf 'jj-mirror: %d thread(s) NOT mirrored (rolled back): %s\n' "$failed" "${failed_threads[*]}" >&2
    printf 'jj-mirror: fix each so its diff applies cleanly onto its prime root, then re-sync.\n' >&2
    exit "$worst_rc"
  fi
}

status_main() {
  validate_source_bookmarks_or_die

  local leaf chain source_name existing state hs hp dname sroot proot sc pc
  local -a parts
  while IFS=$'\t' read -r leaf chain; do
    [[ -n "$leaf" && -n "$chain" ]] || continue
    printf 'thread %s\n' "$leaf"
    if [[ "$(rule_squash_for "$leaf")" == "true" ]]; then
      dname=$(dest_for "$leaf"); sroot=$(resolve_source_root "$leaf")
      existing=$(jj log --no-graph -r "$dname" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
      if [[ -z "$existing" ]]; then state="missing"
      else
        hs=$(range_diff_hash "$sroot" "$leaf") || hs=""
        hp=$(diff_hash "$existing") || hp=""
        if [[ "$hs" == "$hp" && -n "$hs" ]]; then state="ok"; else state="stale"; fi
      fi
      printf '  %s -> %s (squash)    [%s]\n' "$leaf" "$dname" "$state"
      continue
    fi
    parts=()
    IFS='|' read -ra parts <<< "$chain"
    sroot=$(resolve_source_root "$leaf")
    proot=$(resolve_prime_root "$leaf")
    for source_name in "${parts[@]}"; do
      dname=$(dest_for "$source_name")
      existing=$(jj log --no-graph -r "$dname" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
      if [[ -z "$existing" ]]; then
        state="missing"
      else
        # Full-branch faithfulness: compare the CUMULATIVE diff AND commit count of
        # the whole sub-branch (sroot..source) against the prime chain (proot..dest),
        # not just the tip's own diff — else a tip-only / incomplete prime reads "ok".
        hs=$(range_diff_hash "$sroot" "$source_name") || hs=""
        hp=$(range_diff_hash "$proot" "$dname") || hp=""
        sc=$(jj log --no-graph -r "$sroot..\"$source_name\"" -T '"x\n"' 2>/dev/null | awk 'END{print NR}')
        pc=$(jj log --no-graph -r "$proot..\"$dname\"" -T '"x\n"' 2>/dev/null | awk 'END{print NR}')
        if [[ -n "$hs" && "$hs" == "$hp" && "$sc" == "$pc" ]]; then state="ok"; else state="stale"; fi
      fi
      printf '  %s -> %s    [%s]\n' "$source_name" "$dname" "$state"
    done
  done < <(list_source_threads)
}

# status_graph — mirror graph grouped so shared roots coalesce: outer group by
# source root, inner by prime root, then the threads on that (source ──▶ prime)
# edge. A root is marked * when it differs from the global default. Symmetric
# dedup of a shared DEST across different sources would need a bipartite layout;
# the source→prime tree covers the common cases (one shared pair + occasional
# per-pair override). Tip prints on top, base below. Read-only.
status_graph() {
  validate_source_bookmarks_or_die

  local def_src def_dst
  def_src=$(render_root "$SOURCE_ROOT")
  def_dst=$(render_root "$PRIME_ROOT")

  printf 'jj-mirror   ● ok   ◐ stale   ○ missing   ·   * = differs from default root\n'
  printf 'defaults:   %s   ──▶   %s\n\n' "$def_src" "$def_dst"

  # Gather per-thread records into parallel arrays (body = pre-rendered rows).
  local -a t_src=() t_dst=() t_body=() src_order=()
  local -A src_seen=()
  local leaf chain lname slabel plabel body sname dname existing hs hp glyph k row
  local sroot_rev proot_rev sc pc
  local -a parts
  while IFS=$'\t' read -r leaf chain; do
    [[ -n "$leaf" && -n "$chain" ]] || continue
    lname=$(strip_source_prefix "$leaf")
    sroot_rev=$(resolve_source_root "$leaf"); slabel=$(render_root "$sroot_rev")
    proot_rev=$(resolve_prime_root "$leaf"); plabel=$(render_root "$proot_rev")

    body=""
    if [[ "$(rule_squash_for "$leaf")" == "true" ]]; then
      local sq_dest sq_exist sq_h sq_g
      sq_dest=$(dest_for "$leaf")
      sq_exist=$(jj log --no-graph -r "$sq_dest" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
      if [[ -z "$sq_exist" ]]; then sq_g="○"; else
        sq_h=$(range_diff_hash "$(resolve_source_root "$leaf")" "$leaf") || sq_h=""
        hp=$(diff_hash "$sq_exist") || hp=""
        if [[ "$sq_h" == "$hp" && -n "$sq_h" ]]; then sq_g="●"; else sq_g="◐"; fi
      fi
      printf -v row '        ● %-34s ══▶  %s %s (squash)' "$leaf" "$sq_g" "$sq_dest"
      body="$row"$'\n'
    else
    IFS='|' read -ra parts <<< "$chain"
    for (( k=${#parts[@]}-1; k>=0; k-- )); do
      sname=${parts[k]}
      dname=$(dest_for "$sname")
      existing=$(jj log --no-graph -r "$dname" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
      if [[ -z "$existing" ]]; then
        glyph="○"
      else
        hs=$(range_diff_hash "$sroot_rev" "$sname") || hs=""
        hp=$(range_diff_hash "$proot_rev" "$dname") || hp=""
        sc=$(jj log --no-graph -r "$sroot_rev..\"$sname\"" -T '"x\n"' 2>/dev/null | awk 'END{print NR}')
        pc=$(jj log --no-graph -r "$proot_rev..\"$dname\"" -T '"x\n"' 2>/dev/null | awk 'END{print NR}')
        if [[ -n "$hs" && "$hs" == "$hp" && "$sc" == "$pc" ]]; then glyph="●"; else glyph="◐"; fi
      fi
      printf -v row '        ● %-34s ──▶  %s %s' "$sname" "$glyph" "$dname"
      body+="$row"$'\n'
    done
    fi

    t_src+=("$slabel"); t_dst+=("$plabel"); t_body+=("$body")
    if [[ -z "${src_seen[$slabel]:-}" ]]; then src_seen[$slabel]=1; src_order+=("$slabel"); fi
  done < <(list_source_threads)

  (( ${#t_src[@]} )) || { printf '(no source threads)\n'; return 0; }

  # Render: source (outer) → prime (inner) → threads on that edge.
  local s d i smark dmark
  local -a dst_order
  local -A dst_seen
  for s in "${src_order[@]}"; do
    smark=""; [[ "$s" != "$def_src" ]] && smark=" *"
    printf '%s%s\n' "$s" "$smark"
    dst_order=(); dst_seen=()
    for (( i=0; i<${#t_src[@]}; i++ )); do
      [[ "${t_src[i]}" == "$s" ]] || continue
      d=${t_dst[i]}
      [[ -z "${dst_seen[$d]:-}" ]] && { dst_seen[$d]=1; dst_order+=("$d"); }
    done
    for d in "${dst_order[@]}"; do
      dmark=""; [[ "$d" != "$def_dst" ]] && dmark=" *"
      printf '  └─▶ %s%s\n' "$d" "$dmark"
      for (( i=0; i<${#t_src[@]}; i++ )); do
        [[ "${t_src[i]}" == "$s" && "${t_dst[i]}" == "$d" ]] || continue
        printf '%s' "${t_body[i]}"
      done
    done
    printf '\n'
  done
}

# rule_slug PATTERN — deterministic TOML-safe rule name (so re-adding the same
# source overwrites its rule).
rule_slug() { printf '%s' "$1" | tr 'A-Z' 'a-z' | sed 's/[^a-z0-9]/_/g'; }

# add_main — register/overwrite a mirror rule.
add_main() {
  local squash=false src="" dest=""
  while (( $# )); do
    case "$1" in
      --squash) squash=true; shift ;;
      -h|--help) help_add; exit 0 ;;
      -*) echo "jj-mirror: add: unknown flag '$1'" >&2; exit 2 ;;
      *) if [[ -z "$src" ]]; then src=$1
         elif [[ -z "$dest" ]]; then dest=$1
         else echo "jj-mirror: add: too many arguments" >&2; exit 2; fi; shift ;;
    esac
  done
  [[ -n "$src" ]] || { echo "usage: jj-mirror add <source> [<dest>] [--squash]" >&2; exit 2; }
  local slug; slug=$(rule_slug "$src")
  jj config set --repo "jj-mirror.rules.$slug.source" "$src"
  jj config set --repo "jj-mirror.rules.$slug.mirror" true    # add always includes
  if [[ -n "$dest" ]]; then jj config set --repo "jj-mirror.rules.$slug.dest" "$dest"
  else jj config unset "jj-mirror.rules.$slug.dest" 2>/dev/null || true; fi
  if [[ "$squash" == true ]]; then jj config set --repo "jj-mirror.rules.$slug.squash" true
  else jj config unset "jj-mirror.rules.$slug.squash" 2>/dev/null || true; fi
  printf 'jj-mirror: added rule %s — %s -> %s%s\n' \
    "$slug" "$src" "${dest:-<default>}" "$([[ $squash == true ]] && printf ' (squash)')"
}

# rm_main — guarantee SOURCE will not mirror. Removes an exact rule; if a broader
# glob still covers a concrete source, writes an exclusion carve-out.
rm_main() {
  local src=${1:-}
  [[ -n "$src" ]] || { echo "usage: jj-mirror rm <source>" >&2; exit 2; }
  ensure_rules
  local i k removed=0
  for (( i=0; i<${#R_SRC[@]}; i++ )); do
    [[ "${R_NAME[i]}" == "default" ]] && continue
    if [[ "${R_SRC[i]}" == "$src" ]]; then
      for k in source dest squash mirror source-root prime-root; do
        jj config unset "jj-mirror.rules.${R_NAME[i]}.$k" 2>/dev/null || true
      done
      removed=1
    fi
  done
  load_rules   # refresh after removal
  if [[ "$src" != *'*' ]] && is_included "$src"; then
    local es; es=$(rule_slug "$src")
    jj config set --repo "jj-mirror.rules.$es.source" "$src"
    jj config set --repo "jj-mirror.rules.$es.mirror" false
    printf 'jj-mirror: excluded %s (carve-out — a broader rule still covers it)\n' "$src"
  elif (( removed )); then
    printf 'jj-mirror: removed rule(s) for %s\n' "$src"
  else
    echo "jj-mirror: no rule matched '$src'" >&2; exit 1
  fi
}

# list_main — print the mirror rules.
list_main() {
  ensure_rules
  (( ${#R_SRC[@]} > 0 )) || { printf '(no rules)\n'; return 0; }
  printf 'jj-mirror rules (most-specific wins):\n'
  local i flags
  for (( i=0; i<${#R_SRC[@]}; i++ )); do
    flags=""
    [[ "${R_MIRROR[i]}" == "false" ]] && flags+=" EXCLUDE"
    [[ "${R_SQUASH[i]}" == "true"  ]] && flags+=" squash"
    [[ -n "${R_SROOT[i]}" ]] && flags+=" source-root=${R_SROOT[i]}"
    [[ -n "${R_PROOT[i]}" ]] && flags+=" prime-root=${R_PROOT[i]}"
    printf '  %-14s %-14s -> %s%s\n' "${R_NAME[i]}" "${R_SRC[i]}" "${R_DEST[i]:-<default>}" "$flags"
  done
}

abandon_main() {
  local name=${1:-}
  [[ -n "$name" ]] || { echo "usage: jj-mirror abandon <name>" >&2; exit 2; }

  # Wrap the paired delete+abandon in the same atomicity envelope as sync:
  # capture the pre-op id, roll back on any failure. Prevents half-torn state
  # where source is removed but prime lingers (or vice-versa).
  local pre_op
  pre_op=$(capture_pre_op)
  [[ -n "$pre_op" ]] || { echo "jj-mirror: could not capture pre-abandon op id" >&2; exit 1; }

  local full cid
  for full in "${SOURCE_PREFIX}${name}" "${PRIME_PREFIX}${name}"; do
    cid=$(jj log --no-graph -r "$full" -T 'commit_id.short() ++ "\n"' 2>/dev/null | head -n1 || true)
    if [[ -n "$cid" ]]; then
      if ! jj bookmark delete "$full" >/dev/null 2>&1; then
        echo "jj-mirror: bookmark delete failed for $full; rolling back to op $pre_op" >&2
        jj op restore "$pre_op" >/dev/null 2>&1 || true
        exit 1
      fi
      if ! jj abandon "$cid" >/dev/null 2>&1; then
        echo "jj-mirror: abandon failed for $cid; rolling back to op $pre_op" >&2
        jj op restore "$pre_op" >/dev/null 2>&1 || true
        exit 1
      fi
    fi
  done
}

push_main() {
  sync_main

  if command -v jj-vine >/dev/null 2>&1; then
    exec jj-vine submit --tracked
  fi
  # Try `jj vine ...` as a jj subcommand plugin
  if jj vine --help >/dev/null 2>&1; then
    exec jj vine submit --tracked
  fi

  cat >&2 <<'EOF'
jj-mirror: jj-vine not found. Install from https://codeberg.org/abrenneke/jj-vine
Sync succeeded; skipping push.
EOF
  exit 1
}

# wants_help ARG — true when the arg is --help or -h. Used at the top of every
# subcommand's arm so `jj-mirror <cmd> --help` short-circuits without loading
# config or side-effects.
wants_help() { [[ "$1" == "--help" || "$1" == "-h" ]]; }

case "${1:-status}" in
  --help|-h) usage; exit 0 ;;
  help)      print_help "${2:-}"; exit $? ;;
  _dump-config)
    load_config
    printf 'source-prefix=%s\nprime-prefix=%s\nsource-root=%s\nprime-root=%s\n' \
      "$SOURCE_PREFIX" "$PRIME_PREFIX" "$SOURCE_ROOT" "$PRIME_ROOT"
    exit 0
    ;;
  _dump-bookmarks)
    load_config
    case "${2:-}" in
      source) list_source_bookmarks ;;
      prime)  list_prime_bookmarks ;;
      *) echo "usage: jj-mirror _dump-bookmarks source|prime" >&2; exit 2 ;;
    esac
    exit 0
    ;;
  _dump-threads)
    load_config
    list_source_threads
    exit 0
    ;;
  _diff-hash)
    load_config
    [[ -n "${2:-}" ]] || { echo "usage: jj-mirror _diff-hash <revset>" >&2; exit 2; }
    diff_hash "$2"
    exit 0
    ;;
  sync)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_sync; exit 0; fi
    load_config
    parse_sync_flags "$@"
    sync_main
    exit 0
    ;;
  status)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_status; exit 0; fi
    load_config
    case "${1:-}" in
      -g|--graph) status_graph ;;
      "")         status_main ;;
      *) echo "jj-mirror: status: unknown argument '$1'" >&2; exit 2 ;;
    esac
    exit 0
    ;;
  config)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_config; exit 0; fi
    load_config
    config_main
    exit 0
    ;;
  add)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_add; exit 0; fi
    load_config
    add_main "$@"
    exit 0
    ;;
  rm)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_rm; exit 0; fi
    load_config
    rm_main "${1:-}"
    exit 0
    ;;
  list)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_list; exit 0; fi
    load_config
    list_main
    exit 0
    ;;
  _dump-rules)
    load_config
    ensure_rules
    for (( _i=0; _i<${#R_SRC[@]}; _i++ )); do
      printf 'rule\t%s\t%s\t%s\tsquash=%s\tmirror=%s\n' \
        "${R_NAME[_i]}" "${R_SRC[_i]}" "${R_DEST[_i]}" "${R_SQUASH[_i]}" "${R_MIRROR[_i]}"
    done
    exit 0
    ;;
  abandon)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_abandon; exit 0; fi
    load_config
    abandon_main "${1:-}"
    exit 0
    ;;
  push)
    (( $# > 0 )) && shift
    if (( $# > 0 )) && wants_help "$1"; then help_push; exit 0; fi
    load_config
    push_main
    exit 0
    ;;
  *) echo "jj-mirror: unknown command: $1" >&2; usage >&2; exit 2 ;;
esac
