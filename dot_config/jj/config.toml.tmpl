# jj (Jujutsu) config — managed by chezmoi (source: dot_config/jj/config.toml.tmpl).
#
# Per-host, mirroring ~/.config/git/config + git-machine: user.name global,
# user.email chosen per-tree via jj scoped config ([[--scope]]). FAIL-LOUD like
# git's useConfigOnly — NO default email; outside the trees below jj warns until
# a scope matches or you run:
#   jj config set --repo user.email you@example.com   (--repo, NOT --user)
#
# Paths are prefix-matched and `~` expands to $HOME (per jj docs).

[user]
name = "Ian Duggan"

{{ if eq .chezmoi.hostname "blackbird" -}}
# blackbird (work laptop): ALL of ~/work -> golunar; personal in ~/src/ijcd + chezmoi.
[[--scope]]
--when.repositories = ["~/work"]
[--scope.user]
email = "ian@golunar.com"

[[--scope]]
--when.repositories = ["~/src/ijcd", "~/.local/share/chezmoi"]
[--scope.user]
email = "ian@ianduggan.net"
{{- else -}}
# home / other machines (e.g. bearcat): Lunar only under ~/work/lunar -> golunar;
# ~/src and chezmoi personal. (~/work non-lunar stays fail-loud here.)
[[--scope]]
--when.repositories = ["~/work/lunar"]
[--scope.user]
email = "ian@golunar.com"

[[--scope]]
--when.repositories = ["~/src", "~/.local/share/chezmoi"]
[--scope.user]
email = "ian@ianduggan.net"
{{- end }}

# Workflow aliases (host-independent). `mine` = my ijcd/ bookmarks; the restack
# aliases rebase that whole set onto trunk() / local main. `sincemain` = my work
# since local main (swap `local/main` for `trunk()` to measure from remote master).
[revset-aliases]
'mine' = 'bookmarks(regex:"^ijcd/")'
'sincemain' = 'local/main..@'
'sincemaster' = 'trunk()..@'

[aliases]
restack-mine-to-trunk = ["rebase", "-b", "mine", "-d", "trunk()"]
restack-mine = ["rebase", "-b", "mine", "-d", "local/main"]
# restack: -s from the ROOT of the personal stack, NOT local/main's tip. `-s
# local/main` shears the tip + its descendants off a multi-commit base, orphaning
# the base (e.g. settings.json below env-setup) every run. roots(trunk()..local/main)
# = the bottom commit, so -s lifts the whole stack as one unit (works for a 1- or
# N-commit local/main; roots of a single commit is itself). Verified in a scratch repo.
restack = ["rebase", "-s", "roots(trunk()..local/main)", "-d", "trunk()"]
