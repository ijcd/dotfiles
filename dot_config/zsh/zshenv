# Set ZDOTDIR for zsh config location
export ZDOTDIR=~/.config/zsh

# XDG-style locations for tools that need env vars
export INPUTRC=~/.config/readline/inputrc
export IRBRC=~/.config/irb/irbrc

# Debug/profiling flags (set to 1 to enable)
# ZSH_DEBUG=1      # Per-file timing
# ZSH_PROFILE=1    # zprof function profiling

# Source debug utilities first (for file timing)
source $ZDOTDIR/support/debug.zsh
debug_file_start

# Source HM session vars if available
[[ -f /etc/profiles/per-user/$USER/etc/profile.d/hm-session-vars.sh ]] && \
  source /etc/profiles/per-user/$USER/etc/profile.d/hm-session-vars.sh

# User binaries
[[ -d ~/.local/bin ]] && path=(~/.local/bin $path)

# the basics
#: ${HOME=~}                                 # should always be set anyway
#: ${LOGNAME=$(id -un)}                      # should also be set by environment

export LANG=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LANGUAGE=en

# Identity
export EMAIL="ian@ianduggan.net"
export FULLNAME="Ian Duggan"

# IRC
export IRCNICK=ijcd
export IRCNAME=${FULLNAME}

# Debian
export DEBEMAIL=$EMAIL
export DEBFULLNAME=$FULLNAME

# Git identity is intentionally NOT exported here. GIT_AUTHOR_EMAIL /
# GIT_COMMITTER_EMAIL override git config and would defeat the fail-closed guard
# (user.useConfigOnly=true). Identity comes from per-tree includeIf in
# ~/.config/git/config -> git-ijcd / git-work-lunar. A repo outside a configured
# tree fails to commit until an identity is chosen (tree or repo-local).

# Prevent ZSH from stating all of Maildir
export MAILCHECK=0

# Rsync stuff
export RSYNC_RSH=ssh

# Editor
export EDITOR=vim
export VISUAL=$EDITOR

# Claude
export CLAUDE_IMAGE=claude-dev

# Erlang/Elixir - persistent shell history in erl/iex
export ERL_AFLAGS="-kernel shell_history enabled"

# FTP
: ${FTP_PASSIVE:=1}
export FTP_PASSIVE

# Workflow Stuff
export INBOX=~/Desktop/Inbox
export OUTBOX=~/Desktop/Outbox
export PENDING=~/Desktop/Pending
export I=$INBOX
export O=$OUTBOX
export P=$PENDING

debug_file_end
