# dircolor - per-directory terminal background colors
#
# Usage:
#   dircolor            pick a color for current directory
#   dircolor list       show palette + current mappings
#   dircolor set NAME   set current dir to NAME from palette
#   dircolor clear      remove color for current dir
#   dircolor show       show current dir's color
#   dircolor mode       show or set dark/light mode override
#   dircolor apply      apply color for current dir (called by chpwd hook)
#
# Colors are applied via OSC 11 escape sequences (works in kitty, iTerm2, etc.)
# Palette:  $XDG_CONFIG_HOME/dircolor/dir-palette  (name:hex, tracked in chezmoi)
# Mappings: $XDG_CONFIG_HOME/dircolor/dir-colors   (path:name, auto-created)
# Delimiter is last colon — paths with spaces work fine (macOS forbids : in filenames)
#
# When a path has NO explicit mapping in dir-colors, dircolor auto-picks a
# color derived from the SHA of $PWD: hue from hash (~0-359°), fixed
# saturation/lightness chosen for dark or light mode. Adjacent paths hash
# to unrelated hues so distinct dirs look distinct.

_DIRCOLOR_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dircolor"
_DIRCOLOR_PALETTE="$_DIRCOLOR_DIR/dir-palette"
_DIRCOLOR_MAP="$_DIRCOLOR_DIR/dir-colors"

_dircolor_ensure_map() {
  [[ -f $_DIRCOLOR_MAP ]] || touch "$_DIRCOLOR_MAP"
}

# ─── Dark/light mode detection ─────────────────────────────────────────────
# The macOS AppleInterfaceStyle reflects SYSTEM UI theme, not what the
# terminal is actually showing (kitty/ghostty/iTerm background is an
# independent theme setting). So we ask the terminal directly via OSC 11
# query: emit `\e]11;?\e\\` and parse the `rgb:RRRR/GGGG/BBBB` response.
# Perceived luminance decides mode. If no response in ~200ms, default to
# dark (the pragmatic majority-case for terminal usage).
#
# Override: `export DIRCOLOR_MODE=dark` (or `light`) in zshenv skips detection.
_dircolor_detect_mode() {
  if [[ -n $DIRCOLOR_MODE ]]; then
    print -r -- "$DIRCOLOR_MODE"
    return
  fi

  # Only query if we have a real controlling terminal
  if [[ ! -t 1 ]] || [[ ! -c /dev/tty ]]; then
    print dark; return
  fi

  local response=""
  local old_stty
  old_stty=$(stty -g </dev/tty 2>/dev/null) || { print dark; return }
  stty -icanon -echo min 0 time 2 </dev/tty 2>/dev/null
  printf '\033]11;?\033\\' > /dev/tty
  IFS= read -k 40 -t 0.2 response </dev/tty 2>/dev/null
  stty "$old_stty" </dev/tty 2>/dev/null

  # Parse the "rgb:RRRR/GGGG/BBBB" (widths vary by terminal, typically 4 hex each)
  if [[ $response == *rgb:*/*/* ]]; then
    local rgb=${response#*rgb:}
    rgb=${rgb%%$'\e'*}
    rgb=${rgb%%$'\a'*}
    local r16=${rgb%%/*}
    local rest=${rgb#*/}
    local g16=${rest%%/*}
    local b16=${rest#*/}
    local r=$(( 16#${r16:0:2} ))
    local g=$(( 16#${g16:0:2} ))
    local b=$(( 16#${b16:0:2} ))
    # BT.601 perceived luminance: 0.299R + 0.587G + 0.114B (× 1000 for int math)
    local Y=$(( (r*299 + g*587 + b*114) / 1000 ))
    if (( Y < 128 )); then print dark; else print light; fi
    return
  fi

  print dark
}
_DIRCOLOR_MODE=$(_dircolor_detect_mode)

# ─── HSL → RGB integer math (× 1000 for precision) ─────────────────────────
# Given hue (0-359), saturation (0-100), lightness (0-100), sets
# _dircolor_r/_g/_b in 0-255. Integer-only so it works in any zsh.
_dircolor_hsl_to_rgb() {
  local h=$1 s=$2 l=$3
  local L=$((l*10)) S=$((s*10))
  local twoL=$((2*L-1000))
  local absTwoL=$(( twoL<0 ? -twoL : twoL ))
  local C=$(( (1000-absTwoL)*S/1000 ))
  local Hp_x100=$(( h*100/60 ))
  local Hp_mod=$(( Hp_x100 % 200 ))
  local diff=$(( Hp_mod - 100 ))
  local absDiff=$(( diff<0 ? -diff : diff ))
  local X=$(( C*(100-absDiff)/100 ))
  local M=$(( L - C/2 ))

  local Rp Gp Bp
  if   (( h < 60  )); then Rp=$C; Gp=$X; Bp=0
  elif (( h < 120 )); then Rp=$X; Gp=$C; Bp=0
  elif (( h < 180 )); then Rp=0;  Gp=$C; Bp=$X
  elif (( h < 240 )); then Rp=0;  Gp=$X; Bp=$C
  elif (( h < 300 )); then Rp=$X; Gp=0;  Bp=$C
  else                    Rp=$C; Gp=0;  Bp=$X
  fi

  _dircolor_r=$(( (Rp+M) * 255 / 1000 ))
  _dircolor_g=$(( (Gp+M) * 255 / 1000 ))
  _dircolor_b=$(( (Bp+M) * 255 / 1000 ))
}

# Auto-pick a color for a dir with no explicit mapping. Sets _dircolor_r/g/b
# as a side effect (for `dircolor show`/`preview` reuse) and emits OSC 11.
#
# Uses 3 independent bytes of the SHA to spread colors across THREE axes:
#   - hue (first 4 chars → 0-359°) — 360-way variation
#   - lightness delta (next 2 chars → ±L_range) — extra variation so
#     hue-collisions differ in brightness
#   - saturation delta (next 2 chars → ±S_range) — extra vividness spread
# End result: even directories that hash to nearly the same hue look
# distinct because they land on different L / S values.

_dircolor_auto_hue() {
  local dir=$1
  local hash=$(printf '%s' "$dir" | shasum | cut -c1-4)
  print -- $(( 16#$hash % 360 ))
}

# Sets $reply=(h s l) for a dir. Used by _dircolor_auto_apply, show, preview.
_dircolor_auto_hsl() {
  local dir=$1
  local hash=$(printf '%s' "$dir" | shasum | cut -c1-8)
  local h=$(( 16#${hash:0:4} % 360 ))

  local l_base l_range l_min l_max
  local s_base s_range s_min s_max
  case $_DIRCOLOR_MODE in
    light)
      l_base=82; l_range=22; l_min=68; l_max=93     # ±11
      s_base=55; s_range=50; s_min=25; s_max=90     # ±25
      ;;
    *)
      l_base=22; l_range=32; l_min=7;  l_max=40     # ±16 — wide darkness spread
      s_base=75; s_range=50; s_min=45; s_max=100    # ±25 — muted → maxed-out
      ;;
  esac
  local ld=$(( 16#${hash:4:2} % l_range - l_range/2 ))
  local sd=$(( 16#${hash:6:2} % s_range - s_range/2 ))
  local l=$(( l_base + ld ))
  local s=$(( s_base + sd ))
  (( l < l_min )) && l=$l_min
  (( l > l_max )) && l=$l_max
  (( s < s_min )) && s=$s_min
  (( s > s_max )) && s=$s_max

  reply=( "$h" "$s" "$l" )
}

_dircolor_auto_apply() {
  local dir=$1
  local reply
  _dircolor_auto_hsl "$dir"
  _dircolor_hsl_to_rgb "${reply[1]}" "${reply[2]}" "${reply[3]}"
  printf '\033]11;rgb:%02x/%02x/%02x\033\\' \
    "$_dircolor_r" "$_dircolor_g" "$_dircolor_b"
}

_dircolor_apply() {
  local dir=${1:-$PWD}

  # Longest-prefix match on directory paths
  local best_len=0 best_name=""
  if [[ -s $_DIRCOLOR_MAP ]]; then
    local line mpath name
    while read -r line; do
      [[ -n $line && $line != \#* ]] || continue
      mpath=${line%:*}
      name=${line##*:}
      if [[ $dir == ${mpath}* && ${#mpath} -gt $best_len ]]; then
        best_len=${#mpath}
        best_name=$name
      fi
    done < "$_DIRCOLOR_MAP"
  fi

  # No explicit mapping? Auto-pick from PWD hash, sensitive to dark/light mode.
  if [[ -z $best_name ]]; then
    _dircolor_auto_apply "$dir"
    return
  fi

  # Resolve name to hex from palette
  local hex pline
  while read -r pline; do
    [[ -n $pline && $pline != \#* ]] || continue
    if [[ ${pline%:*} == $best_name ]]; then
      hex=${pline##*:}
      break
    fi
  done < "$_DIRCOLOR_PALETTE"
  [[ -z $hex ]] && return

  # Convert #rrggbb to rr/gg/bb for OSC 11
  local r=${hex:1:2} g=${hex:3:2} b=${hex:5:2}
  printf '\033]11;rgb:%s/%s/%s\033\\' "$r" "$g" "$b"
}

# Show or override the dark/light mode.
_dircolor_mode() {
  case ${1:-} in
    "") echo "$_DIRCOLOR_MODE" ;;
    dark|light|auto)
      if [[ $1 == auto ]]; then
        unset DIRCOLOR_MODE
      else
        export DIRCOLOR_MODE=$1
      fi
      _DIRCOLOR_MODE=$(_dircolor_detect_mode)
      echo "$_DIRCOLOR_MODE"
      _dircolor_apply
      ;;
    *) echo "Usage: dircolor mode [dark|light|auto]" >&2; return 1 ;;
  esac
}

_dircolor_list() {
  echo "Available colors:"
  echo ""
  local line name hex
  while read -r line; do
    [[ -n $line && $line != \#* ]] || continue
    name=${line%:*}
    hex=${line##*:}
    local r=$((16#${hex:1:2})) g=$((16#${hex:3:2})) b=$((16#${hex:5:2}))
    printf '  \033[48;2;%d;%d;%dm  %-8s  \033[0m  %s\n' "$r" "$g" "$b" "$name" "$hex"
  done < "$_DIRCOLOR_PALETTE"

  echo ""
  echo "Current mappings:"
  _dircolor_ensure_map
  local has_mappings=0
  while read -r line; do
    [[ -n $line && $line != \#* ]] || continue
    echo "  ${line%:*} -> ${line##*:}"
    has_mappings=1
  done < "$_DIRCOLOR_MAP"
  (( has_mappings == 0 )) && echo "  (none)"
}

_dircolor_set() {
  local name=$1
  local dir=$PWD

  if [[ -z $name ]]; then
    echo "Usage: dircolor set <name>" >&2
    return 1
  fi

  # Verify name exists in palette
  local found=0 line
  while read -r line; do
    [[ ${line%:*} == $name ]] && { found=1; break; }
  done < "$_DIRCOLOR_PALETTE"
  if (( ! found )); then
    echo "Unknown color: $name" >&2
    echo "Run 'dircolor list' to see available colors" >&2
    return 1
  fi

  _dircolor_ensure_map
  # Remove existing entry for this dir, then append
  grep -v "^${dir}:" "$_DIRCOLOR_MAP" > "$_DIRCOLOR_MAP.tmp" 2>/dev/null
  command mv "$_DIRCOLOR_MAP.tmp" "$_DIRCOLOR_MAP"
  printf '%s:%s\n' "$dir" "$name" >> "$_DIRCOLOR_MAP"

  echo "Set $dir -> $name"
  _dircolor_apply
}

_dircolor_pick() {
  local -a names
  local -A palette
  local line name hex
  while read -r line; do
    [[ -n $line && $line != \#* ]] || continue
    name=${line%:*}
    hex=${line##*:}
    [[ $name == default ]] && continue
    palette[$name]=$hex
    names+=($name)
  done < "$_DIRCOLOR_PALETTE"

  echo "Pick a color for $PWD:"
  echo ""
  local i=1
  for name in ${(o)names}; do
    hex=${palette[$name]}
    local r=$((16#${hex:1:2})) g=$((16#${hex:3:2})) b=$((16#${hex:5:2}))
    printf '  %2d) \033[48;2;%d;%d;%dm  %-8s  \033[0m\n' "$i" "$r" "$g" "$b" "$name"
    (( i++ ))
  done
  echo ""

  local choice
  read "choice?Enter number or name: "

  local selected
  if [[ $choice =~ ^[0-9]+$ ]]; then
    selected=${${(o)names}[$choice]}
  else
    selected=$choice
  fi

  if [[ -z $selected ]] || ! (( ${+palette[$selected]} )); then
    echo "Invalid choice" >&2
    return 1
  fi

  _dircolor_set "$selected"
}

_dircolor_clear() {
  local dir=$PWD
  _dircolor_ensure_map
  grep -v "^${dir}:" "$_DIRCOLOR_MAP" > "$_DIRCOLOR_MAP.tmp" 2>/dev/null
  command mv "$_DIRCOLOR_MAP.tmp" "$_DIRCOLOR_MAP"
  echo "Cleared color for $dir"
  _dircolor_apply
}

_dircolor_show() {
  local dir=$PWD
  _dircolor_ensure_map
  local best_name="" best_len=0
  local line mpath name
  while read -r line; do
    [[ -n $line && $line != \#* ]] || continue
    mpath=${line%:*}
    name=${line##*:}
    if [[ $dir == ${mpath}* && ${#mpath} -gt $best_len ]]; then
      best_name=$name
      best_len=${#mpath}
    fi
  done < "$_DIRCOLOR_MAP"

  if [[ -n $best_name ]]; then
    # Resolve to hex for display
    local hex pline
    while read -r pline; do
      [[ -n $pline && $pline != \#* ]] || continue
      [[ ${pline%:*} == $best_name ]] && { hex=${pline##*:}; break; }
    done < "$_DIRCOLOR_PALETTE"
    echo "$dir -> $best_name ($hex)"
  else
    # Auto-color: compute + describe
    local reply
    _dircolor_auto_hsl "$dir"
    _dircolor_hsl_to_rgb "${reply[1]}" "${reply[2]}" "${reply[3]}"
    printf '%s -> auto (h=%d° s=%d%% l=%d%%, %s mode) #%02x%02x%02x\n' \
      "$dir" "${reply[1]}" "${reply[2]}" "${reply[3]}" "$_DIRCOLOR_MODE" \
      "$_dircolor_r" "$_dircolor_g" "$_dircolor_b"
  fi
}

# ─── preview: swatch every subdir of a target (or ~/work by default) ───
_dircolor_preview() {
  local target=${1:-$PWD}
  target=${target/#\~/$HOME}
  if [[ ! -d $target ]]; then
    echo "Not a directory: $target" >&2
    return 1
  fi
  local reply
  _dircolor_auto_hsl "$target"
  _dircolor_hsl_to_rgb "${reply[1]}" "${reply[2]}" "${reply[3]}"
  printf '  \033[48;2;%d;%d;%dm     ●     \033[0m  h=%3d° s=%d%% l=%d%%  #%02x%02x%02x  %s (SELF)\n' \
    "$_dircolor_r" "$_dircolor_g" "$_dircolor_b" \
    "${reply[1]}" "${reply[2]}" "${reply[3]}" \
    "$_dircolor_r" "$_dircolor_g" "$_dircolor_b" \
    "$target"

  local d
  for d in $target/*(N/); do
    _dircolor_auto_hsl "$d"
    _dircolor_hsl_to_rgb "${reply[1]}" "${reply[2]}" "${reply[3]}"
    printf '  \033[48;2;%d;%d;%dm     ●     \033[0m  h=%3d° s=%d%% l=%d%%  #%02x%02x%02x  %s\n' \
      "$_dircolor_r" "$_dircolor_g" "$_dircolor_b" \
      "${reply[1]}" "${reply[2]}" "${reply[3]}" \
      "$_dircolor_r" "$_dircolor_g" "$_dircolor_b" \
      "${d##*/}"
  done
}

dircolor() {
  case ${1:-pick} in
    list)  _dircolor_list ;;
    set)   _dircolor_set "$2" ;;
    clear) _dircolor_clear ;;
    show)  _dircolor_show ;;
    pick)  _dircolor_pick ;;
    apply) _dircolor_apply ;;
    mode)  _dircolor_mode "$2" ;;
    preview) _dircolor_preview "$2" ;;
    *)     echo "Usage: dircolor [list|set NAME|clear|show|pick|mode|preview]" >&2 ;;
  esac
}
