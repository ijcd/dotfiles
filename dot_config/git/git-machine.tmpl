{{- /* Per-host git identity trees, rendered by chezmoi from the hostname.
       Fail-loud: any repo outside these trees refuses to commit (useConfigOnly
       is set in the main config). Paths are relative to ~/.config/git/. */ -}}
# Generated by chezmoi (source: dot_config/git/git-machine.tmpl) for {{ .chezmoi.hostname }}.
{{ if eq .chezmoi.hostname "blackbird" -}}
# blackbird (work laptop): ALL of ~/work -> Lunar; personal only in ~/src/ijcd
# and the chezmoi source. Everything else fails loud.
[includeIf "gitdir:~/work/"]
	path = git-work-lunar
[includeIf "gitdir:~/src/ijcd/"]
	path = git-ijcd
[includeIf "gitdir:~/.local/share/chezmoi/"]
	path = git-ijcd
{{- else -}}
# home / other machines (e.g. bearcat): ~/work personal by default, Lunar only
# under ~/work/lunar; ~/src and chezmoi personal.
[includeIf "gitdir:~/work/"]
	path = git-ijcd
[includeIf "gitdir:~/work/lunar/"]
	path = git-work-lunar
[includeIf "gitdir:~/src/"]
	path = git-ijcd
[includeIf "gitdir:~/.local/share/chezmoi/"]
	path = git-ijcd
{{- end }}
